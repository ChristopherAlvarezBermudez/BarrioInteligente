@model BarrioInteligenteWeb.Models.Usuario
@{
    Layout = null;
    ViewData["Title"] = "Editar Perfil";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Editar Perfil — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <style>
        .perfil-body {
            flex: 1;
            padding: 32px 24px 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        .form-edit {
            width: 100%;
            background: #f9f9f9;
            border: 1px solid #ebebeb;
            border-radius: 12px;
            padding: 18px 16px;
        }
        .form-edit-title {
            font-size: 16px;
            font-weight: 800;
            color: #111;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .form-group {
            margin-bottom: 12px;
        }
        .form-group label {
            font-size: 12px;
            font-weight: 600;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: block;
            margin-bottom: 4px;
        }
        .form-group input {
            width: 100%;
            padding: 10px 12px;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            color: #111;
            outline: none;
            transition: border-color 0.15s;
        }
        .form-group input:focus {
            border-color: #111;
        }
        .pass-current {
            background: #fff5f5 !important;
            border-color: #ffcccc !important;
        }
        .pass-current:focus {
            border-color: #e74c3c !important;
        }
        .divider { width: 100%; height: 1px; background: #ebebeb; }
    </style>
</head>
<body>
<div class="app-screen">

    <header class="app-header d-flex align-items-center justify-content-between" style="padding: 16px 24px; background: #fff; border-bottom: 1px solid #ebebeb;">
        <a href="@Url.Action("Perfil", "Account")" class="text-dark d-flex align-items-center" style="text-decoration: none;">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
            </svg>
        </a>
        <span class="app-title m-0" style="font-size: 18px; font-weight: 700;">Editar Perfil</span>
        <div style="width:24px;"></div> <!-- Spacer para centrar el título -->
    </header>

    <div class="perfil-body">

        @if (ViewBag.Error != null)
        {
            <div style="width:100%;background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;padding:10px 14px;font-size:13px;color:#c0392b;">
                @ViewBag.Error
            </div>
        }

        <div class="form-edit">
            <div class="form-edit-title">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125"/>
                </svg>
                Actualiza tus datos
            </div>
            
            <form asp-controller="Account" asp-action="SolicitarEdicionPerfil" method="post">
                @Html.AntiForgeryToken()
                
                <div class="form-group">
                    <label>Nuevo Nombre (opcional)</label>
                    <input type="text" name="nuevoNombre" value="@Model.NombreCompleto" placeholder="Tu nombre" required />
                </div>
                
                <div class="form-group">
                    <label>Nuevo Correo (opcional)</label>
                    <input type="email" name="nuevoCorreo" value="@Model.Correo" placeholder="tu@correo.com" required />
                </div>
                
                <div class="form-group">
                    <label>Nueva Contraseña (opcional)</label>
                    <input type="password" name="nuevaPassword" placeholder="Solo si deseas cambiarla" minlength="6" />
                </div>
                
                <div class="form-group">
                    <label>Confirmar Nueva Contraseña</label>
                    <input type="password" name="confirmarNuevaPassword" placeholder="Solo si ingresaste una nueva" minlength="6" />
                </div>
                
                <div class="divider" style="margin: 14px 0;"></div>
                
                <div class="form-group">
                    <label style="color:#c0392b;">Contraseña actual (Requerida para guardar)</label>
                    <input type="password" name="passwordActual" class="pass-current" placeholder="Tu contraseña actual" required />
                </div>
                
                <button type="submit" class="btn-primary-black w-100" style="margin-top: 8px;">
                    Guardar Cambios
                </button>
            </form>
        </div>

        <!-- ── ZONA DE PELIGRO ── -->
        <div class="form-edit" style="border-color: #f5c6cb; background-color: #fdf2f2; margin-top: 4px;">
            <div class="form-edit-title" style="color: #721c24;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
                Zona de Peligro
            </div>
            <p style="font-size: 13px; color: #721c24; margin-bottom: 12px;">
                Una vez que elimines tu cuenta, no hay vuelta atrás. Por favor, asegúrate de estar seguro.
            </p>
            <form asp-controller="Account" asp-action="ProgramarEliminacion" method="post">
                @Html.AntiForgeryToken()
                <div class="form-group">
                    <label style="color:#721c24;">Contraseña actual (Requerida para confirmar)</label>
                    <input type="password" name="passwordActual" class="pass-current" placeholder="Tu contraseña actual" required />
                </div>
                <button type="submit" class="btn-primary-black w-100" style="margin-top: 8px; background-color: #dc3545; border-color: #dc3545; color: white;">
                    Eliminar mi cuenta
                </button>
            </form>
        </div>
    </div>
</div>
</body>
</html>
