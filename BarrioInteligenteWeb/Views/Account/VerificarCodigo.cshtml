@{
    Layout = null;
    ViewData["Title"] = "Verificar código";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Verificar código — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <style>
        .auth-screen { max-width: 430px; min-height: 100dvh; margin: 0 auto; background: #fff; display: flex; flex-direction: column; justify-content: center; padding: 40px 28px 60px; }
        .auth-title { font-size: 26px; font-weight: 800; color: #111; margin-bottom: 6px; }
        .auth-subtitle { font-size: 14px; color: #888; margin-bottom: 36px; }
        .auth-field { margin-bottom: 16px; }
        .auth-field label { font-size: 12px; font-weight: 600; color: #555; text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 6px; }
        .auth-field input { width: 100%; padding: 14px 16px; background: #f5f5f5; border: 2px solid transparent; border-radius: 12px; font-size: 22px; letter-spacing: 8px; color: #111; outline: none; text-align: center; transition: border-color 0.15s; }
        .auth-field input:focus { border-color: #111; background: #fff; }
        .auth-error { background: #fff0f0; border: 1px solid #ffcccc; border-radius: 10px; padding: 12px 14px; font-size: 13px; color: #c0392b; margin-bottom: 20px; }
        .auth-link { text-align: center; margin-top: 20px; font-size: 14px; color: #666; }
        .auth-link a { color: #111; font-weight: 700; text-decoration: none; }
        .info-box { background: #f0f7ff; border: 1px solid #cce0ff; border-radius: 10px; padding: 12px 14px; font-size: 13px; color: #1a5fa8; margin-bottom: 20px; }
    </style>
</head>
<body>
<div class="auth-screen">

    <div class="text-center" style="margin-bottom: 40px;">
        <img src="~/images/LogoBI.png" alt="Barrio Inteligente" style="max-height: 72px; width: auto; object-fit: contain;" />
    </div>

    <h1 class="auth-title">Verificar código</h1>
    <p class="auth-subtitle">Ingresa el código de 6 dígitos que enviamos a tu correo.</p>

    <div class="info-box">
        Código enviado a: <strong>@ViewBag.Correo</strong>. Válido por 15 minutos.
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="auth-error">@ViewBag.Error</div>
    }

    <form asp-controller="Account" asp-action="VerificarCodigo" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="correo" value="@ViewBag.Correo" />

        <div class="auth-field">
            <label for="codigo">Código de verificación</label>
            <input type="text" id="codigo" name="codigo" placeholder="000000" maxlength="6"
                   pattern="\d{6}" inputmode="numeric" autocomplete="one-time-code" required />
        </div>

        <button type="submit" class="btn-primary-black mt-3">
            VERIFICAR
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
        </button>
    </form>

    <p class="auth-link">
        <a href="@Url.Action("OlvidePassword", "Account")">← Solicitar un nuevo código</a>
    </p>

</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
