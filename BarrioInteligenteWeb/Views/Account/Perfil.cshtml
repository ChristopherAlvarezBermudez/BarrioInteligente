@model BarrioInteligenteWeb.Models.Usuario
@{
    Layout = null;
    ViewData["Title"] = "Perfil";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Perfil — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <style>
        .perfil-body {
            flex: 1;
            padding: 32px 24px 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        .avatar-grande {
            width: 88px;
            height: 88px;
            background: #111;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            overflow: hidden;
            cursor: pointer;
            position: relative;
        }
        .avatar-grande img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .avatar-overlay {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: rgba(0,0,0,.35);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity .2s;
        }
        .avatar-grande:hover .avatar-overlay { opacity: 1; }
        .perfil-nombre {
            font-size: 22px;
            font-weight: 800;
            color: #111;
            margin: 0;
            text-align: center;
        }
        .perfil-correo {
            font-size: 14px;
            color: #888;
            margin: 0;
        }
        .foto-hint {
            font-size: 12px;
            color: #aaa;
            margin-top: -12px;
        }
        .perfil-dato {
            width: 100%;
            background: #f5f5f5;
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .perfil-dato label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #aaa;
        }
        .perfil-dato span {
            font-size: 15px;
            color: #111;
            font-weight: 500;
        }
        .divider { width: 100%; height: 1px; background: #ebebeb; }
        
        .form-edit {
            width: 100%;
            background: #f9f9f9;
            border: 1px solid #ebebeb;
            border-radius: 12px;
            padding: 18px 16px;
            margin-top: 10px;
        }
        .form-edit-title {
            font-size: 16px;
            font-weight: 800;
            color: #111;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .form-group {
            margin-bottom: 12px;
        }
        .form-group label {
            font-size: 12px;
            font-weight: 600;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            display: block;
            margin-bottom: 4px;
        }
        .form-group input {
            width: 100%;
            padding: 10px 12px;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 14px;
            color: #111;
            outline: none;
            transition: border-color 0.15s;
        }
        .form-group input:focus {
            border-color: #111;
        }
        .pass-current {
            background: #fff5f5 !important;
            border-color: #ffcccc !important;
        }
        .pass-current:focus {
            border-color: #e74c3c !important;
        }

        /* ── Reputación Ciudadana Card ── */
        .rep-card {
            width: 100%;
            background: #fff;
            border: 1px solid #ebebeb;
            border-radius: 16px;
            padding: 18px 16px 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,.05);
        }
        .rep-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }
        .rep-icon-wrap {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .rep-title {
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #aaa;
            margin: 0;
        }
        .rep-status {
            font-size: 17px;
            font-weight: 800;
            margin: 0 0 4px;
            line-height: 1.2;
        }
        .rep-motivo {
            font-size: 13px;
            color: #666;
            margin: 0 0 16px;
            line-height: 1.5;
        }
        /* Stepper */
        .rep-stepper {
            display: flex;
            align-items: center;
            width: 100%;
            margin-top: 4px;
        }
        .rep-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 0 0 auto;
            position: relative;
            z-index: 1;
        }
        .rep-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 3px solid;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            transition: transform .2s;
        }
        .rep-dot.active {
            transform: scale(1.25);
            box-shadow: 0 0 0 4px rgba(0,0,0,.07);
        }
        .rep-step-label {
            font-size: 9px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .3px;
            margin-top: 6px;
            white-space: nowrap;
        }
        .rep-connector {
            flex: 1;
            height: 3px;
            border-radius: 2px;
            margin-bottom: 20px; /* Offset to align with dots, not labels */
        }
        /* Color palette */
        .rep-excelente  { color: #16a34a; border-color: #16a34a; }
        .rep-buena      { color: #22c55e; border-color: #22c55e; }
        .rep-regular    { color: #eab308; border-color: #eab308; }
        .rep-mala       { color: #f97316; border-color: #f97316; }
        .rep-critica    { color: #dc2626; border-color: #dc2626; }
        .rep-line-excelente { background: #16a34a; }
        .rep-line-buena     { background: #22c55e; }
        .rep-line-regular   { background: #eab308; }
        .rep-line-mala      { background: #f97316; }
        .rep-line-inactive  { background: #e5e7eb; }
        /* ── Avatar Rings (Gamificación estilo Discord) ── */
        .avatar-wrapper {
            position: relative;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            cursor: pointer;
        }
        /* Excelente: anillo dorado/verde degradado con neón y shimmer */
        .avatar-excellent > .avatar-grande {
            box-shadow: 0 0 0 4px #fff, 0 0 0 7px #16a34a, 0 0 18px 4px rgba(22,163,74,.45);
        }
        .avatar-excellent::before {
            content: '';
            position: absolute;
            inset: -7px;
            border-radius: 50%;
            background: conic-gradient(from 0deg, #fbbf24, #16a34a, #4ade80, #fbbf24);
            animation: ring-spin 4s linear infinite;
            z-index: 0;
        }
        .avatar-excellent > .avatar-grande {
            position: relative;
            z-index: 1;
        }
        @@keyframes ring-spin {
            to { transform: rotate(360deg); }
        }
        /* Estrella insignia para Excelente */
        .avatar-badge {
            position: absolute;
            bottom: -2px;
            right: -2px;
            width: 26px;
            height: 26px;
            background: linear-gradient(135deg, #fbbf24, #f59e0b);
            border-radius: 50%;
            border: 2px solid #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            z-index: 10;
            box-shadow: 0 2px 6px rgba(0,0,0,.2);
            animation: badge-pop .4s cubic-bezier(.34,1.56,.64,1) both;
        }
        @@keyframes badge-pop {
            from { transform: scale(0); opacity: 0; }
            to   { transform: scale(1); opacity: 1; }
        }
        /* Buena: aro plateado/azulado */
        .avatar-buena > .avatar-grande {
            box-shadow: 0 0 0 4px #fff, 0 0 0 7px #3b82f6, 0 0 12px 2px rgba(59,130,246,.3);
        }
        /* Regular: aro gris mínimo */
        .avatar-regular > .avatar-grande {
            box-shadow: 0 0 0 4px #fff, 0 0 0 6px #d1d5db;
        }
        /* Mala / Crítica: toque rojo sutil */
        .avatar-mala > .avatar-grande,
        .avatar-critica > .avatar-grande {
            box-shadow: 0 0 0 4px #fff, 0 0 0 6px #f87171;
        }

        /* ── Modal Insignia ── */
        .badge-modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 9999;
            align-items: flex-end;
            justify-content: center;
        }
        .badge-modal-overlay.open {
            display: flex;
            animation: overlay-in .2s ease;
        }
        @@keyframes overlay-in {
            from { opacity: 0; } to { opacity: 1; }
        }
        .badge-modal {
            background: #fff;
            border-radius: 24px 24px 0 0;
            padding: 28px 24px 40px;
            width: 100%;
            max-width: 430px;
            text-align: center;
            animation: modal-up .3s cubic-bezier(.34,1.2,.64,1) both;
        }
        @@keyframes modal-up {
            from { transform: translateY(100%); } to { transform: translateY(0); }
        }
        .badge-modal-icon {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            margin: 0 auto 16px;
        }
        .badge-modal-title {
            font-size: 20px;
            font-weight: 800;
            color: #111;
            margin: 0 0 8px;
        }
        .badge-modal-desc {
            font-size: 14px;
            color: #666;
            line-height: 1.6;
            margin: 0 0 24px;
        }
        .badge-modal-close {
            width: 100%;
            padding: 14px;
            border-radius: 14px;
            background: #111;
            color: #fff;
            border: none;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
        }
    </style>
</head>
<body>
<div class="app-screen">

    <header class="app-header">
        <span class="app-title">Mi Perfil</span>
        <div style="width:36px;"></div>
    </header>

    <div class="perfil-body">

        @if (ViewBag.Error != null)
        {
            <div style="width:100%;background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;padding:10px 14px;font-size:13px;color:#c0392b;">
                @ViewBag.Error
            </div>
        }

        @{
            /* Helpers de reputación */
            var rep = Model.Reputacion;
            string repStatusText = rep switch {
                BarrioInteligenteWeb.Models.NivelReputacion.Excelente => "Tu cuenta tiene una reputación excelente",
                BarrioInteligenteWeb.Models.NivelReputacion.Buena     => "Tu cuenta tiene buena reputación",
                BarrioInteligenteWeb.Models.NivelReputacion.Regular   => "Tu reputación es regular",
                BarrioInteligenteWeb.Models.NivelReputacion.Mala      => "Tu reputación necesita mejorar",
                BarrioInteligenteWeb.Models.NivelReputacion.Critica   => "Tu cuenta está en estado crítico",
                _ => "Estado de reputación desconocido"
            };
            // ── Anillo del avatar ──
            string avatarRingClass = rep switch {
                BarrioInteligenteWeb.Models.NivelReputacion.Excelente => "avatar-excellent",
                BarrioInteligenteWeb.Models.NivelReputacion.Buena     => "avatar-buena",
                BarrioInteligenteWeb.Models.NivelReputacion.Regular   => "avatar-regular",
                BarrioInteligenteWeb.Models.NivelReputacion.Mala      => "avatar-mala",
                BarrioInteligenteWeb.Models.NivelReputacion.Critica   => "avatar-critica",
                _ => ""
            };
            bool isExcelente = rep == BarrioInteligenteWeb.Models.NivelReputacion.Excelente;
            bool hasBadge = rep == BarrioInteligenteWeb.Models.NivelReputacion.Excelente
                         || rep == BarrioInteligenteWeb.Models.NivelReputacion.Buena;
            string repColor = rep switch {
                BarrioInteligenteWeb.Models.NivelReputacion.Excelente => "#16a34a",
                BarrioInteligenteWeb.Models.NivelReputacion.Buena     => "#22c55e",
                BarrioInteligenteWeb.Models.NivelReputacion.Regular   => "#ca8a04",
                BarrioInteligenteWeb.Models.NivelReputacion.Mala      => "#ea580c",
                BarrioInteligenteWeb.Models.NivelReputacion.Critica   => "#dc2626",
                _ => "#6b7280"
            };
            string repIconBg = rep switch {
                BarrioInteligenteWeb.Models.NivelReputacion.Excelente => "#dcfce7",
                BarrioInteligenteWeb.Models.NivelReputacion.Buena     => "#dcfce7",
                BarrioInteligenteWeb.Models.NivelReputacion.Regular   => "#fef9c3",
                BarrioInteligenteWeb.Models.NivelReputacion.Mala      => "#ffedd5",
                BarrioInteligenteWeb.Models.NivelReputacion.Critica   => "#fee2e2",
                _ => "#f3f4f6"
            };
            string repMotivo = string.IsNullOrWhiteSpace(Model.MotivoReputacion)
                ? "Gracias por respetar las normas comunitarias y contribuir al bienestar del barrio."
                : Model.MotivoReputacion;
            int repIdx = (int)rep; /* 0=Excelente … 4=Critica */
            /* Datos de cada paso del stepper */
            var steps = new[]
            {
                new { Label = "Excelente", Cls = "rep-excelente",  LineCls = "rep-line-excelente" },
                new { Label = "Buena",     Cls = "rep-buena",      LineCls = "rep-line-buena"     },
                new { Label = "Regular",   Cls = "rep-regular",    LineCls = "rep-line-regular"   },
                new { Label = "Mala",      Cls = "rep-mala",       LineCls = "rep-line-mala"      },
                new { Label = "Crítica",   Cls = "rep-critica",    LineCls = "rep-line-inactive"  }
            };
        }

        <!-- Avatar tap-to-upload envuelto en avatar-wrapper con anillo -->
        <form asp-controller="Account" asp-action="SubirFoto" method="post" enctype="multipart/form-data" id="fotoForm">
            @Html.AntiForgeryToken()
            <input type="file" id="fotoInput" name="foto" accept="image/jpeg,image/png,image/webp"
                   style="display:none" />
            <div class="avatar-wrapper @avatarRingClass" id="avatarWrapper" title="Ver insignia">
                <div class="avatar-grande" id="avatarGrande">
                    @if (!string.IsNullOrEmpty(Model.FotoPerfil))
                    {
                        <img id="avatarPreview" src="@Model.FotoPerfil" alt="Foto de perfil" />
                    }
                    else
                    {
                        <svg id="avatarSvg" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="44" height="44">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                        </svg>
                        <img id="avatarPreview" src="" alt="" style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    }
                    <div class="avatar-overlay">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="white" width="22" height="22">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                        </svg>
                    </div>
                </div>
                @if (isExcelente)
                {
                    <!-- Insignia estrella dorada para Excelente -->
                    <div class="avatar-badge" title="Ciudadano Excelente">⭐</div>
                }
                else if (hasBadge)
                {
                    <!-- Insignia escudo azul para Buena -->
                    <div class="avatar-badge" style="background: linear-gradient(135deg,#3b82f6,#2563eb);" title="Buena Reputación">🛡</div>
                }
            </div>
        </form>
        <p class="foto-hint">Toca para ver insignia · Mantén para cambiar foto</p>

        <p class="perfil-nombre">@Model.NombreCompleto</p>
        <p class="perfil-correo">@Model.Correo</p>

        <div class="divider"></div>

        <div class="perfil-dato" style="width:100%">
            <label>Miembro desde</label>
            <span>@Model.FechaRegistro.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-DO"))</span>
        </div>


        <!-- ── TARJETA REPUTACIÓN CIUDADANA ── -->
        <div class="rep-card">
            <div class="rep-header">
                <div class="rep-icon-wrap" style="background: @repIconBg;">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="@repColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                    </svg>
                </div>
                <p class="rep-title">Reputación Ciudadana</p>
            </div>
            <p class="rep-status" style="color: @repColor;">@repStatusText</p>
            <p class="rep-motivo">@repMotivo</p>

            <!-- Stepper horizontal -->
            <div class="rep-stepper">
                @for (int i = 0; i < steps.Length; i++)
                {
                    bool isActive = (i == repIdx);
                    bool isPast   = (i < repIdx);
                    string dotCls = steps[i].Cls + (isActive ? " active" : "");
                    string dotBg  = isActive ? "#fff" : (isPast ? "currentColor" : "#fff");

                    <div class="rep-step">
                        <div class="rep-dot @dotCls" style="@(isPast ? $"background:{steps[i].Cls.Replace("rep-","")};" : "")">       
                            @if (isActive)
                            {
                                <!-- Check activo -->
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="@steps[i].Cls" width="13" height="13" style="display:block;">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                                </svg>
                            }
                            else if (isPast)
                            {
                                <!-- Dot relleno pasado -->
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 8 8" width="8" height="8">
                                    <circle cx="4" cy="4" r="3" fill="white"/>
                                </svg>
                            }
                        </div>
                        <span class="rep-step-label @steps[i].Cls">@steps[i].Label</span>
                    </div>
                    @if (i < steps.Length - 1)
                    {
                        string lineCls = (i < repIdx) ? steps[i].LineCls : "rep-line-inactive";
                        <div class="rep-connector @lineCls"></div>
                    }
                }
            </div>
        </div>

        <div style="width: 100%; margin-top: 10px;">
            <a href="@Url.Action("EditarPerfil", "Account")" class="btn-primary-black w-100" style="display: flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none;">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125"/>
                </svg>
                Editar Perfil
            </a>
        </div>

        <form asp-controller="Account" asp-action="Logout" method="post" style="width:100%;margin-top:8px;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-dark w-100 d-flex justify-content-center align-items-center gap-2" style="height: 48px; border-radius: 12px; font-weight: 700; font-size: 14px;">
                Cerrar sesión
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
                </svg>
            </button>
        </form>
    </div>

    <nav class="bottom-nav">
        <a href="@Url.Action("Index", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c-.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/>
            </svg>
            <span>Mapa</span>
        </a>
        <a href="@Url.Action("MisReportes", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
