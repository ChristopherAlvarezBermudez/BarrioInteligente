<!-- ── Modal Insignia de Reputación ── -->
<div class="badge-modal-overlay" id="badgeModal">
    <div class="badge-modal">
        <div class="badge-modal-icon" id="badgeModalIcon" style="background:#dcfce7;">⭐</div>
        <p class="badge-modal-title" id="badgeModalTitle">Insignia de Ciudadano Excelente</p>
        <p class="badge-modal-desc" id="badgeModalDesc">Gracias por contribuir al bienestar del barrio.</p>
        <button class="badge-modal-close" id="badgeModalClose">Entendido</button>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // ─── Datos de insignias por nivel ───
    const insignias = {
        'excelente': {
            icon: '⭐',
            iconBg: 'linear-gradient(135deg,#fbbf24,#16a34a)',
            title: 'Insignia de Ciudadano Excelente',
            desc: 'Tu participación sobresaliente fortalece el bienestar colectivo. Sigues siendo un pilar fundamental de este barrio. ¡Gracias por tu compromiso!'
        },
        'buena': {
            icon: '🛡',
            iconBg: 'linear-gradient(135deg,#3b82f6,#2563eb)',
            title: 'Insignia de Ciudadano con Buena Reputación',
            desc: 'Tienes una buena reputación en la comunidad. Sigue reportando problemas y participando para alcanzar el nivel Excelente.'
        },
        'regular': {
            icon: '💬',
            iconBg: '#fef9c3',
            title: 'Reputación Regular',
            desc: 'Tu reputación es regular. Participa más activamente — reporta problemas, valida reportes de otros y mantén un comportamiento positivo.'
        },
        'mala': {
            icon: '⚠️',
            iconBg: '#ffedd5',
            title: 'Reputación necesita mejorar',
            desc: 'Tu reputación requiere atención. Evita reportes duplicados o erróneos y ayuda a otros ciudadanos para subir tu puntuación.'
        },
        'critica': {
            icon: '🚨',
            iconBg: '#fee2e2',
            title: 'Estado Crítico',
            desc: 'Tu cuenta está en estado crítico. Participa positivamente en la comunidad para recuperar tu reputación y acceder a más funciones.'
        }
    };
    const nivelActual = '@rep.ToString().ToLower()';

    // ─── Avatar wrapper: clic corto → modal, long press → upload ───
    const wrapper = document.getElementById('avatarWrapper');
    const fotoInput = document.getElementById('fotoInput');
    let pressTimer = null;

    if (wrapper) {
        wrapper.addEventListener('mousedown', () => {
            pressTimer = setTimeout(() => {
                pressTimer = null;
                fotoInput.click();
            }, 600);
        });
        wrapper.addEventListener('mouseup', () => { clearTimeout(pressTimer); });
        wrapper.addEventListener('mouseleave', () => { clearTimeout(pressTimer); });

        // Toque en móvil
        wrapper.addEventListener('touchstart', () => {
            pressTimer = setTimeout(() => {
                pressTimer = null;
                fotoInput.click();
            }, 600);
        }, { passive: true });
        wrapper.addEventListener('touchend', (e) => {
            if (pressTimer) {
                clearTimeout(pressTimer);
                // Tap corto → abrir modal
                e.preventDefault();
                abrirModal();
            }
        });

        // Click en escritorio = abrir modal (upload sólo con long-press)
        wrapper.addEventListener('click', (e) => {
            if (pressTimer) {
                clearTimeout(pressTimer);
                abrirModal();
            }
        });
    }

    function abrirModal() {
        const data = insignias[nivelActual] || insignias['regular'];
        document.getElementById('badgeModalIcon').textContent = data.icon;
        document.getElementById('badgeModalIcon').style.background = data.iconBg;
        document.getElementById('badgeModalTitle').textContent = data.title;
        document.getElementById('badgeModalDesc').textContent = data.desc;
        document.getElementById('badgeModal').classList.add('open');
    }

    document.getElementById('badgeModalClose').addEventListener('click', () => {
        document.getElementById('badgeModal').classList.remove('open');
    });
    document.getElementById('badgeModal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('badgeModal'))
            document.getElementById('badgeModal').classList.remove('open');
    });

    // ─── Upload foto ───
    if (fotoInput) {
        fotoInput.addEventListener('change', function () {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    const preview = document.getElementById('avatarPreview');
                    const svg = document.getElementById('avatarSvg');
                    if (preview) {
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                        if (svg) svg.style.display = 'none';
                    }
                };
                reader.readAsDataURL(this.files[0]);
                document.getElementById('fotoForm').submit();
            }
        });
    }
</script>
</body>
</html>
