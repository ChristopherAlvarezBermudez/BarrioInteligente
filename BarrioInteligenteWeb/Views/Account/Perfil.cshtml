@model BarrioInteligenteWeb.Models.Usuario
@{
    Layout = null;
    ViewData["Title"] = "Perfil";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Perfil — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <style>
        .perfil-body {
            flex: 1;
            padding: 32px 24px 100px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }
        .avatar-grande {
            width: 88px;
            height: 88px;
            background: #111;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            overflow: hidden;
            cursor: pointer;
            position: relative;
        }
        .avatar-grande img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
        }
        .avatar-overlay {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            background: rgba(0,0,0,.35);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity .2s;
        }
        .avatar-grande:hover .avatar-overlay { opacity: 1; }
        .perfil-nombre {
            font-size: 22px;
            font-weight: 800;
            color: #111;
            margin: 0;
            text-align: center;
        }
        .perfil-correo {
            font-size: 14px;
            color: #888;
            margin: 0;
        }
        .foto-hint {
            font-size: 12px;
            color: #aaa;
            margin-top: -12px;
        }
        .perfil-dato {
            width: 100%;
            background: #f5f5f5;
            border-radius: 12px;
            padding: 14px 16px;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .perfil-dato label {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #aaa;
        }
        .perfil-dato span {
            font-size: 15px;
            color: #111;
            font-weight: 500;
        }
        .divider { width: 100%; height: 1px; background: #ebebeb; }
    </style>
</head>
<body>
<div class="app-screen">

    <header class="app-header">
        <span class="app-title">Mi Perfil</span>
        <div style="width:36px;"></div>
    </header>

    <div class="perfil-body">

        @if (ViewBag.Error != null)
        {
            <div style="width:100%;background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;padding:10px 14px;font-size:13px;color:#c0392b;">
                @ViewBag.Error
            </div>
        }

        <!-- Avatar tap-to-upload -->
        <form asp-controller="Account" asp-action="SubirFoto" method="post" enctype="multipart/form-data" id="fotoForm">
            @Html.AntiForgeryToken()
            <input type="file" id="fotoInput" name="foto" accept="image/jpeg,image/png,image/webp"
                   style="display:none" />
            <div class="avatar-grande" onclick="document.getElementById('fotoInput').click()" title="Cambiar foto de perfil">
                @if (!string.IsNullOrEmpty(Model.FotoPerfil))
                {
                    <img id="avatarPreview" src="@Model.FotoPerfil" alt="Foto de perfil" />
                }
                else
                {
                    <svg id="avatarSvg" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="44" height="44">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                    </svg>
                    <img id="avatarPreview" src="" alt="" style="display:none;position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                }
                <div class="avatar-overlay">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="white" width="22" height="22">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                    </svg>
                </div>
            </div>
        </form>
        <p class="foto-hint">Toca la foto para cambiarla</p>

        <p class="perfil-nombre">@Model.NombreCompleto</p>
        <p class="perfil-correo">@Model.Correo</p>

        <div class="divider"></div>

        <div class="perfil-dato" style="width:100%">
            <label>Miembro desde</label>
            <span>@Model.FechaRegistro.ToString("dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-DO"))</span>
        </div>

        <form asp-controller="Account" asp-action="Logout" method="post" style="width:100%;margin-top:8px;">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-primary-black" style="background:#fff;color:#111;border:2px solid #111;">
                Cerrar sesión
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
                </svg>
            </button>
        </form>
    </div>

    <nav class="bottom-nav">
        <a href="@Url.Action("Index", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c-.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/>
            </svg>
            <span>Mapa</span>
        </a>
        <a href="@Url.Action("MisReportes", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
            </svg>
            <span>Mis Reportes</span>
        </a>
        <a href="@Url.Action("Comunidad", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
            </svg>
            <span>Comunidad</span>
        </a>
    </nav>

</div>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const fotoInput = document.getElementById('fotoInput');
    if (fotoInput) {
        fotoInput.addEventListener('change', function () {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    // Si ya hay img visible, actualiza su src
                    const preview = document.getElementById('avatarPreview');
                    const svg = document.getElementById('avatarSvg');
                    if (preview) {
                        preview.src = e.target.result;
                        preview.style.display = 'block';
                        if (svg) svg.style.display = 'none';
                    }
                };
                reader.readAsDataURL(this.files[0]);
                // Envía el form automáticamente tras seleccionar
                document.getElementById('fotoForm').submit();
            }
        });
    }
</script>
</body>
</html>
