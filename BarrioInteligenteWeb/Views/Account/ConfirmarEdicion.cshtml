@{
    Layout = null;
    ViewData["Title"] = "Confirmar Edición";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Confirmar Edición — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
</head>
<body class="auth-bg">
    <div class="auth-container">
        <div class="auth-card">
            <h2 class="auth-title">Verifica el cambio 🔒</h2>
            <p class="auth-subtitle">Ingresa el código que acabamos de enviar a tu correo electrónico actual para autorizar los cambios en tu perfil.</p>
            
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger" style="border-radius:12px; font-size:14px; padding:10px;">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="ConfirmarEdicion" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="editNombre" value="@ViewBag.EditNombre" />
                <input type="hidden" name="editCorreo" value="@ViewBag.EditCorreo" />
                <input type="hidden" name="editPassword" value="@ViewBag.EditPassword" />
                
                <div class="form-group mb-3">
                    <label class="form-label">Código numérico</label>
                    <input type="text" name="codigo" class="form-control barrio-input-text" maxlength="6" pattern="\d{6}" placeholder="Ej: 123456" required style="font-size:24px; text-align:center; letter-spacing:4px; font-weight:700;" autocomplete="off" />
                </div>
                
                <button type="submit" class="btn-primary-black w-100 mt-2">
                    Validar y Guardar Cambios
                </button>
            </form>
            
            <a href="@Url.Action("Perfil", "Account")" class="auth-link d-block text-center mt-4">
                Cancelar y volver al Perfil
            </a>
        </div>
    </div>
</body>
</html>
