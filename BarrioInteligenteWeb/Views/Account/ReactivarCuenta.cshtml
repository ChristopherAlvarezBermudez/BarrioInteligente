@{
    Layout = null;
    ViewData["Title"] = "Reactivar Cuenta";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Reactivar Cuenta — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <style>
        .auth-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fafafa;
            padding: 24px;
        }
        .auth-card {
            background: #fff;
            border-radius: 20px;
            padding: 32px 24px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.06);
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        .auth-title {
            font-size: 24px;
            font-weight: 800;
            color: #111;
            text-align: center;
            margin: 0;
        }
        .alert-danger {
            background-color: #fdf2f2;
            border-color: #f5c6cb;
            color: #721c24;
            border-radius: 12px;
            padding: 16px;
            font-size: 14px;
            text-align: center;
        }
        .countdown {
            font-size: 18px;
            font-weight: 700;
            color: #e74c3c;
            margin-top: 8px;
            display: block;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">
            
            <h1 class="auth-title">Cuenta en proceso de eliminación</h1>
            
            <div class="alert-danger">
                Tu cuenta está programada para ser eliminada permanentemente.
                <span class="countdown" id="countdownTimer">Calculando tiempo...</span>
            </div>

            @if (ViewBag.Error != null)
            {
                <div style="background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;padding:10px 14px;font-size:13px;color:#c0392b;margin-bottom:15px;">
                    @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="ReactivarCuenta" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="usuarioId" value="@ViewBag.UsuarioId" />
                
                <div class="form-group" style="margin-bottom:15px;">
                    <label style="font-size: 12px; font-weight: 600; color: #555; display: block; margin-bottom: 4px;">Contraseña actual</label>
                    <input type="password" name="password" style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; outline: none; font-size:14px;" placeholder="Ingresa tu contraseña" required />
                </div>
                
                <button type="submit" class="btn-primary-black" style="width: 100%; padding: 14px; border-radius: 12px; font-weight: 600; border: none; background: #111; color: #fff; cursor: pointer;">
                    Cancelar eliminación y reactivar cuenta
                </button>
            </form>

            <div style="text-align: center; margin-top: 10px;">
                <a href="@Url.Action("Login", "Account")" style="color: #666; font-size: 14px; text-decoration: none; font-weight: 500;">Volver al Inicio de Sesión</a>
            </div>
        </div>
    </div>

    <script>
        var targetDateStr = '@ViewBag.FechaEliminacion';
        if (targetDateStr) {
            var targetDate = new Date(targetDateStr).getTime();
            
            var x = setInterval(function() {
                var now = new Date().getTime();
                var distance = targetDate - now;
                
                if (distance < 0) {
                    clearInterval(x);
                    document.getElementById("countdownTimer").innerHTML = "Tiempo agotado";
                    window.location.href = '@Url.Action("Login", "Account")';
                    return;
                }
                
                var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((distance % (1000 * 60)) / 1000);
                
                document.getElementById("countdownTimer").innerHTML = "Tiempo restante: " + hours + "h " + minutes + "m " + seconds + "s";
            }, 1000);
        }
    </script>
</body>
</html>
