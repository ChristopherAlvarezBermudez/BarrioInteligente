@model IEnumerable<BarrioInteligenteWeb.Models.Reporte>
@{
    Layout = null;
    ViewData["Title"] = "Mapa";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        /* ── Control de Mapa de Calor (Leaflet custom control) ── */
        .heatmap-control {
            position: relative;
        }
        .heatmap-toggle-btn {
            width: 36px;
            height: 36px;
            background: #fff;
            border: 2px solid rgba(0,0,0,0.2);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 1px 5px rgba(0,0,0,0.25);
            transition: background 0.15s, border-color 0.15s;
            padding: 0;
            font-size: 18px;
            line-height: 1;
        }
        .heatmap-toggle-btn:hover {
            background: #f4f4f4;
        }
        .heatmap-toggle-btn.active {
            background: #111;
            border-color: #111;
        }
        .heatmap-toggle-btn.active .heatmap-icon-off { display: none; }
        .heatmap-toggle-btn:not(.active) .heatmap-icon-on { display: none; }
        .heatmap-icon-on { filter: brightness(10); }

        .heatmap-dropdown {
            display: none;
            position: absolute;
            top: 42px;
            right: 0;
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.18);
            min-width: 170px;
            overflow: hidden;
            z-index: 1001;
            animation: hd-fade-in 0.15s ease;
        }
        .heatmap-dropdown.open {
            display: block;
        }
        @@keyframes hd-fade-in {
            from { opacity: 0; transform: translateY(-6px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .heatmap-dropdown-header {
            padding: 10px 14px 6px;
            font-size: 11px;
            font-weight: 700;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .heatmap-dropdown-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            font-size: 13px;
            font-weight: 600;
            color: #333;
            cursor: pointer;
            transition: background 0.12s;
            border: none;
            background: none;
            width: 100%;
            text-align: left;
        }
        .heatmap-dropdown-item:hover {
            background: #f5f5f5;
        }
        .heatmap-dropdown-item.selected {
            background: #111;
            color: #fff;
        }
        .heatmap-dropdown-item .cat-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .heatmap-dropdown-divider {
            height: 1px;
            background: #eee;
            margin: 0;
        }
        .heatmap-dropdown-item.off-btn {
            color: #c0392b;
            font-weight: 700;
        }
        .heatmap-dropdown-item.off-btn:hover {
            background: #fff0f0;
        }

        /* ── Control de Filtro por Estado ── */
        .estado-filter-control {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 1px 5px rgba(0,0,0,0.25);
            border: 2px solid rgba(0,0,0,0.2);
            overflow: hidden;
            display: none;
            flex-direction: row;
        }
        .estado-filter-control.visible {
            display: flex;
        }
        .estado-filter-btn {
            border: none;
            background: #fff;
            padding: 6px 12px;
            font-size: 11px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.12s, color 0.12s;
            color: #666;
            white-space: nowrap;
        }
        .estado-filter-btn:first-child {
            border-right: 1px solid #eee;
        }
        .estado-filter-btn:hover {
            background: #f5f5f5;
        }
        .estado-filter-btn.active {
            background: #111;
            color: #fff;
        }

        #mapa {
            width: 100%;
            height: calc(100dvh - 57px - 64px);
        }

        /* Boton GPS */
        .leaflet-gps-btn {
            width: 34px;
            height: 34px;
            background: #fff;
            border: 2px solid rgba(0,0,0,0.25);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 1px 5px rgba(0,0,0,0.25);
            transition: background 0.15s;
            padding: 0;
        }
        .leaflet-gps-btn:hover {
            background: #f4f4f4;
        }
        .leaflet-gps-btn svg {
            width: 18px;
            height: 18px;
            color: #555;
            transition: color 0.15s;
        }
        .leaflet-gps-btn.locating svg {
            color: #4285F4;
            animation: gps-spin 1s linear infinite;
        }
        .leaflet-gps-btn.located svg {
            color: #4285F4;
        }
        @@keyframes gps-spin {
            from { transform: rotate(0deg); }
            to   { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
<div class="app-screen">

    <header class="app-header">
        <img src="~/images/LogoBI.png" alt="Barrio Inteligente" style="max-height: 26px; width: auto; object-fit: contain;" />
        @{
            string? fotoPerfil = ViewBag.FotoPerfil as string;
        }
        <a href="@Url.Action("Perfil", "Account")" class="btn-user-icon" title="Mi perfil" aria-label="Mi perfil"
           style="@(!string.IsNullOrEmpty(fotoPerfil) ? "padding:0;overflow:hidden;border-radius:50%;" : "")">
            @if (!string.IsNullOrEmpty(fotoPerfil))
            {
                <img src="@fotoPerfil" alt="Mi perfil" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;" />
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                </svg>
            }
        </a>
    </header>


    <div id="mapa"></div>

    <!-- FAB fijo encima del bottom nav -->
    <a href="@Url.Action("Crear", "Reportes")" class="fab-fixed" aria-label="Crear reporte">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="26" height="26">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
    </a>

    <nav class="bottom-nav">
        <a href="@Url.Action("Index", "Reportes")" class="active">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/>
            </svg>
            <span>Mapa</span>
        </a>
        <a href="@Url.Action("MisReportes", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
            </svg>
            <span>Mis Reportes</span>
        </a>
        <a href="@Url.Action("Comunidad", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
            </svg>
            <span>Comunidad</span>
        </a>
        <a href="@Url.Action("Dashboard", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            </svg>
            <span>Panel</span>
        </a>
    </nav>

    <!-- ── Toast de Bootstrap para Notificaciones SignalR ── -->
    <div class="toast-container position-fixed top-0 start-50 translate-middle-x p-3 mt-5" style="z-index: 9999;">
        <div id="liveToast" class="toast align-items-center text-bg-dark border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
            <div class="toast-header bg-dark text-white border-dark">
                <span style="font-size: 1.2rem; margin-right: 8px;">🚨</span>
                <strong class="me-auto font-monospace">¡Nuevo Reporte en la zona!</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toastBody" style="font-size: 14px;">
                <!-- Se llenará dinámicamente -->
            </div>
        </div>
    </div>

</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.12/signalr.min.js"></script>
<script>
    const reportes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.Select(r => new {
            r.Id,
            r.Titulo,
            r.Categoria,
            r.Estado,
            r.Upvotes,
            r.Latitud,
            r.Longitud,
            r.DireccionFisica,
            r.Descripcion,
            detallesUrl = Url.Action("Detalles", "Reportes", new { id = r.Id }),
            foto = string.IsNullOrWhiteSpace(r.ImagenUrl) ? "" : r.ImagenUrl
        }),
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }
    ));

    const reportesConCoordenadas = reportes.filter(r => r.latitud !== 0 || r.longitud !== 0);

    let defaultLat = 18.4861;
    let defaultLon = -69.9312;

    if (reportesConCoordenadas.length > 0) {
        defaultLat = reportesConCoordenadas[0].latitud;
        defaultLon = reportesConCoordenadas[0].longitud;
    }

    const map = L.map('mapa').setView([defaultLat, defaultLon], 15);
    setTimeout(() => { map.invalidateSize(); }, 100);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© <a href="https://www.openstreetmap.org/">OpenStreetMap</a>',
        maxZoom: 19
    }).addTo(map);

    const emojiCategoria = { 'Bache': '🚧', 'Basura': '🗑️', 'Luz': '💡', 'Otro': '📍' };

    function truncarTexto(texto, maxLength) {
        if (!texto) return '';
        if (texto.length <= maxLength) return texto;
        return texto.substring(0, maxLength) + '...';
    }

    let marcadoresNormales = [];

    reportes.forEach(reporte => {
        if (reporte.latitud === 0 && reporte.longitud === 0) return;

        const emoji = emojiCategoria[reporte.categoria] || '📍';
        const icon = L.divIcon({
            html: `<div style="font-size:26px;filter:drop-shadow(0 1px 3px rgba(0,0,0,.4));line-height:1;">${emoji}</div>`,
            className: '',
            iconSize: [34, 34],
            iconAnchor: [17, 17]
        });

        const ubicacionMostrada = reporte.direccionFisica || "Ubicación sin dirección";
        const descripcionTruncada = truncarTexto(reporte.descripcion, 90);

        let fotoHtml = reporte.foto && reporte.foto.trim() !== "" 
            ? `<img src="${reporte.foto}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; flex-shrink: 0; border: 1px solid #ccc;" alt="Foto" onerror="this.outerHTML='<div style=\\'width:50px;height:50px;border-radius:8px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;\\'>📷</div>'">`
            : `<div style="width: 50px; height: 50px; border-radius: 8px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;">📷</div>`;

        const marker = L.marker([reporte.latitud, reporte.longitud], { icon })
            .bindPopup(`
                <div style="display: flex; gap: 10px; padding-bottom: 4px; align-items: flex-start; font-family:'Inter',sans-serif; min-width: 240px; max-width: 280px;">
                    ${fotoHtml}
                    <div style="flex-grow: 1; min-width: 0;">
                        <h6 style="margin: 0 0 4px 0; font-size: 14px; font-weight: bold; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${reporte.titulo}</h6>
                        <p style="margin: 0 0 6px 0; font-size: 11px; color: #666; line-height: 1.2;">
                            📍 ${reporte.direccionFisica || 'Ubicación'}
                        </p>
                        <p style="margin: 0 0 8px 0; font-size: 11px; color: #888;">
                            ${reporte.categoria} • ${reporte.estado}
                        </p>
                        <a href="/Reportes/Detalles/${reporte.id}" style="display: inline-block; background: #212529; color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; text-decoration: none; font-weight: bold;">Ver detalles →</a>
                    </div>
                </div>
            `, { maxWidth: 280, minWidth: 240 });
            
        marker.addTo(map);
        marcadoresNormales.push(marker);
    });

    // ── Mapa de Calor Multitarea ──
    let categoriaActual = null;
    let calorActivo = false;
    let reportesCalorActuales = [];
    let estadoActual = 'Activos';

    const categoriasDisponibles = [
        { nombre: 'Basura',  emoji: '🗑️', color: '#e67e22' },
        { nombre: 'Bache',   emoji: '🚧', color: '#e74c3c' },
        { nombre: 'Luz',     emoji: '💡', color: '#f1c40f' },
        { nombre: 'Otro',    emoji: '📍', color: '#9b59b6' }
    ];

    // Configuración visual del heatmap (reutilizada en cada recreación)
    const heatmapOpts = {
        radius: 40,
        blur: 35,
        maxZoom: 17,
        gradient: { 0.4: 'blue', 0.6: 'lime', 0.8: 'yellow', 1.0: 'red' }
    };

    let capaCalor = null;

    /**
     * Carga el mapa de calor para la categoría seleccionada.
     * Patrón: Destruir capa anterior → Crear nueva instancia.
     */
    function cargarMapaCalorPorCategoria(categoriaSeleccionada) {
        categoriaActual = categoriaSeleccionada;

        const url = '@Url.Action("ObtenerCoordenadasCalor", "Reportes")' +
                    '?categoria=' + encodeURIComponent(categoriaSeleccionada) +
                    '&estadoFiltro=' + encodeURIComponent(estadoActual);

        fetch(url)
            .then(response => {
                if (!response.ok) throw new Error('Error HTTP: ' + response.status);
                return response.json();
            })
            .then(data => {
                // Guardar datos enriquecidos para clics interactivos
                reportesCalorActuales = data;

                // Mapear al formato que necesita L.heatLayer: [lat, lng, intensidad]
                const heatData = data.map(d => [d.lat, d.lng, d.intensidad]);

                // Destruir capa anterior si existe
                if (capaCalor) {
                    map.removeLayer(capaCalor);
                    capaCalor = null;
                }

                // Crear capa nueva desde cero con los datos frescos
                capaCalor = L.heatLayer(heatData, heatmapOpts).addTo(map);

                // Ocultar marcadores normales si es la primera activación
                if (!calorActivo) {
                    marcadoresNormales.forEach(m => map.removeLayer(m));
                }
                calorActivo = true;

                // Actualizar UI del control
                const toggleBtn = document.querySelector('.heatmap-toggle-btn');
                if (toggleBtn) toggleBtn.classList.add('active');
                actualizarDropdownSeleccion();
            })
            .catch(error => {
                console.error('[MapaCalor] Error al cargar categoría:', error);
            });
    }

    /** Desactiva el mapa de calor y restaura los marcadores normales. */
    function desactivarMapaCalor() {
        // Destruir la capa completamente
        if (capaCalor) {
            map.removeLayer(capaCalor);
            capaCalor = null;
        }
        categoriaActual = null;
        calorActivo = false;
        reportesCalorActuales = [];
        marcadoresNormales.forEach(m => map.addLayer(m));

        const toggleBtn = document.querySelector('.heatmap-toggle-btn');
        if (toggleBtn) toggleBtn.classList.remove('active');
        actualizarDropdownSeleccion();
    }

    // ── Clic interactivo en zona de calor (Efecto Snapchat) ──
    map.on('click', function (e) {
        if (!calorActivo || reportesCalorActuales.length === 0) return;

        const radioBusquedaMetros = 150;
        const reportesEncontrados = [];

        reportesCalorActuales.forEach(function (reporte) {
            const latLngReporte = L.latLng(reporte.lat, reporte.lng);
            if (e.latlng.distanceTo(latLngReporte) <= radioBusquedaMetros) {
                reportesEncontrados.push(reporte);
            }
        });

        if (reportesEncontrados.length > 0) {
            let htmlLista = '';
            reportesEncontrados.forEach(r => {
                let fotoHtml = r.foto && r.foto.trim() !== "" 
                    ? `<img src="${r.foto}" style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px; flex-shrink: 0; border: 1px solid #ccc;" alt="Foto" onerror="this.outerHTML='<div style=\\'width:50px;height:50px;border-radius:8px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;\\'>📷</div>'">`
                    : `<div style="width: 50px; height: 50px; border-radius: 8px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;">📷</div>`;

                htmlLista += `
                    <div style="display: flex; gap: 10px; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid #e0e0e0; align-items: flex-start;">
                        ${fotoHtml}
                        <div style="flex-grow: 1; min-width: 0;">
                            <h6 style="margin: 0 0 4px 0; font-size: 14px; font-weight: bold; line-height: 1.2; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${r.titulo}</h6>
                            <p style="margin: 0 0 6px 0; font-size: 11px; color: #666; line-height: 1.2;">
                                📍 ${r.direccion || 'Ubicación'}
                            </p>
                            <p style="margin: 0 0 8px 0; font-size: 11px; color: #888;">
                                ${r.categoria} • ${r.estado}
                            </p>
                            <a href="/Reportes/Detalles/${r.id}" style="display: inline-block; background: #212529; color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; text-decoration: none; font-weight: bold;">Ver detalles →</a>
                        </div>
                    </div>
                `;
            });

            const htmlPopup = `
                <div style="font-family:'Inter',sans-serif;min-width:240px;max-width:280px;">
                    <h6 style="color:#ff4500;font-weight:800;margin:0 0 4px;font-size:14px;">🔥 Zona Caliente</h6>
                    <p style="font-size:12px;color:#666;margin:0 0 12px;font-weight:500;">
                        ${reportesEncontrados.length} reporte${reportesEncontrados.length > 1 ? 's' : ''} en esta zona
                    </p>
                    <div style="max-height:240px;overflow-y:auto;padding-right:4px;">
                        ${htmlLista}
                    </div>
                </div>
            `;

            L.popup({ maxWidth: 280, minWidth: 240 })
                .setLatLng(e.latlng)
                .setContent(htmlPopup)
                .openOn(map);
        }
    });

    /** Marca visualmente la categoría seleccionada en el dropdown. */
    function actualizarDropdownSeleccion() {
        document.querySelectorAll('.heatmap-dropdown-item[data-cat]').forEach(item => {
            item.classList.toggle('selected', item.dataset.cat === categoriaActual);
        });
    }

    // Actualización automática cada 30 segundos usando categoriaActual
    setInterval(() => {
        if (calorActivo && categoriaActual) {
            cargarMapaCalorPorCategoria(categoriaActual);
        }
    }, 30000);

    // ── Control Leaflet personalizado (esquina superior derecha) ──
    const HeatmapControl = L.Control.extend({
        options: { position: 'topright' },
        onAdd: function () {
            const container = L.DomUtil.create('div', 'heatmap-control leaflet-bar');
            L.DomEvent.disableClickPropagation(container);
            L.DomEvent.disableScrollPropagation(container);

            // Botón principal
            const btn = L.DomUtil.create('button', 'heatmap-toggle-btn', container);
            btn.title = 'Mapa de calor por categoría';
            btn.setAttribute('aria-label', 'Mapa de calor por categoría');
            btn.innerHTML = `
                <span class="heatmap-icon-off" style="font-size:17px;">🔥</span>
                <span class="heatmap-icon-on" style="font-size:17px;">🔥</span>
            `;

            // Dropdown
            const dropdown = L.DomUtil.create('div', 'heatmap-dropdown', container);

            let ddHTML = '<div class="heatmap-dropdown-header">Categoría</div>';
            categoriasDisponibles.forEach(cat => {
                ddHTML += `
                    <button class="heatmap-dropdown-item" data-cat="${cat.nombre}">
                        <span class="cat-dot" style="background:${cat.color}"></span>
                        ${cat.emoji} ${cat.nombre}
                    </button>`;
            });
            ddHTML += '<div class="heatmap-dropdown-divider"></div>';
            ddHTML += '<button class="heatmap-dropdown-item off-btn">✕ Desactivar</button>';
            dropdown.innerHTML = ddHTML;

            // Toggle dropdown on click
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                dropdown.classList.toggle('open');
            });

            // Categoría seleccionada
            dropdown.querySelectorAll('.heatmap-dropdown-item[data-cat]').forEach(item => {
                item.addEventListener('click', () => {
                    cargarMapaCalorPorCategoria(item.dataset.cat);
                    dropdown.classList.remove('open');
                });
            });

            // Botón desactivar
            dropdown.querySelector('.off-btn').addEventListener('click', () => {
                desactivarMapaCalor();
                dropdown.classList.remove('open');
            });

            // Cerrar dropdown al hacer clic fuera
            document.addEventListener('click', () => {
                dropdown.classList.remove('open');
            });

            return container;
        }
    });
    new HeatmapControl().addTo(map);

    // ── Control de Filtro por Estado (debajo del control de categorías) ──
    const EstadoFilterControl = L.Control.extend({
        options: { position: 'topright' },
        onAdd: function () {
            const container = L.DomUtil.create('div', 'estado-filter-control leaflet-bar');
            L.DomEvent.disableClickPropagation(container);

            container.innerHTML = `
                <button class="estado-filter-btn active" data-estado="Activos">🔴 Activos</button>
                <button class="estado-filter-btn" data-estado="Resueltos">🟢 Resueltos</button>
            `;

            container.querySelectorAll('.estado-filter-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    // Actualizar UI
                    container.querySelectorAll('.estado-filter-btn').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');

                    // Actualizar estado y refrescar si hay mapa de calor activo
                    estadoActual = btn.dataset.estado;
                    if (calorActivo && categoriaActual) {
                        cargarMapaCalorPorCategoria(categoriaActual);
                    }
                });
            });

            return container;
        }
    });
    const estadoControl = new EstadoFilterControl();
    estadoControl.addTo(map);

    // Mostrar/ocultar el control de estado según si el heatmap está activo
    const observarEstadoControl = new MutationObserver(() => {
        const ctrl = document.querySelector('.estado-filter-control');
        if (ctrl) ctrl.classList.toggle('visible', calorActivo);
    });
    // Polling sencillo: sincronizar visibilidad del control de estado
    setInterval(() => {
        const ctrl = document.querySelector('.estado-filter-control');
        if (ctrl) ctrl.classList.toggle('visible', calorActivo);
    }, 300);

    // Centrado inicial GPS
    if (navigator.geolocation && reportesConCoordenadas.length === 0) {
        navigator.geolocation.getCurrentPosition(pos => {
            map.setView([pos.coords.latitude, pos.coords.longitude], 15);
        });
    }

    // Control GPS
    let userLocationMarker = null;

    const GpsControl = L.Control.extend({
        options: { position: 'topleft' },
        onAdd: function () {
            const btn = L.DomUtil.create('button', 'leaflet-gps-btn');
            btn.title = 'Mostrar mi ubicación';
            btn.setAttribute('aria-label', 'Mostrar mi ubicación');
            btn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                     stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7Z" />
                    <circle cx="12" cy="9" r="2.5" fill="currentColor" stroke="none" />
                </svg>`;

            L.DomEvent.on(btn, 'click', function (e) {
                L.DomEvent.stopPropagation(e);
                btn.classList.remove('located');
                btn.classList.add('locating');
                map.locate({
                    setView: true,
                    maxZoom: 18,
                    enableHighAccuracy: false,
                    timeout: 30000,
                    maximumAge: 60000
                });
            });

            return btn;
        }
    });
    const gpsControl = new GpsControl();
    gpsControl.addTo(map);

    // GPS encontrado
    map.on('locationfound', function (e) {
        const btn = document.querySelector('.leaflet-gps-btn');
        if (btn) { btn.classList.remove('locating'); btn.classList.add('located'); }

        if (userLocationMarker) {
            userLocationMarker.setLatLng(e.latlng);
        } else {
            userLocationMarker = L.circleMarker(e.latlng, {
                radius: 10,
                color: '#fff',
                weight: 3,
                fillColor: '#4285F4',
                fillOpacity: 0.9
            }).addTo(map);
        }

        const accuracy = Math.round(e.accuracy);
        const lowAccuracy = accuracy > 100;

        if (lowAccuracy) {
            console.warn(`[GPS] Precisión baja: ±${accuracy} m. El dispositivo puede estar usando solo red/Wi-Fi.`);
        }

        userLocationMarker.bindPopup(`
            <div style="font-family:'Inter',sans-serif;font-size:13px;color:#111;font-weight:600;">
                📍 Estás aquí
                <br><small style="color:${lowAccuracy ? '#e07000' : '#777'};font-weight:400;">
                    Precisión: ±${accuracy} m${lowAccuracy ? ' ⚠️ (baja precisión)' : ''}
                </small>
            </div>
        `).openPopup();
    });

    // Error GPS
    map.on('locationerror', function (e) {
        const btn = document.querySelector('.leaflet-gps-btn');
        if (btn) { btn.classList.remove('locating', 'located'); }

        const msg = e.code === 1
            ? 'Permiso de ubicación denegado. Actívalo en la configuración de tu navegador.'
            : 'No se pudo obtener tu ubicación. Intenta de nuevo.';
        alert(msg);
    });

    // ── SignalR: Tiempo Real ──
    const connection = new signalR.HubConnectionBuilder().withUrl("/reportesHub").build();

    connection.on("RecibirNuevoReporte", function (lat, lng, titulo, categoria) {
        // Llenar y mostrar el Toast de Bootstrap
        document.getElementById('toastBody').innerText = `${categoria}: ${titulo}`;
        const toastEl = document.getElementById('liveToast');
        const toast = new bootstrap.Toast(toastEl);
        toast.show();

        // Si el reporte tiene ubicación, agregarlo para el mapa de calor
        if (lat !== 0 || lng !== 0) {
            reportesCalorActuales.push({ 
                lat: lat, 
                lng: lng, 
                titulo: titulo, 
                categoria: categoria, 
                intensidad: 1, 
                foto: "", 
                estado: "Pendiente" 
            });
            
            // Refrescar mapa de calor si la categoría que estamos viendo es la misma o si aplica.
            if (calorActivo && (categoriaActual === categoria || categoriaActual === null)) {
                cargarMapaCalorPorCategoria(categoriaActual || categoria);
            }
        }
    });

    connection.start().catch(err => console.error("[SignalR] Error al conectar:", err));

</script>
</body>
</html>