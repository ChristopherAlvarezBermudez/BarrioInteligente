@using BarrioInteligenteWeb.Helpers
@using BarrioInteligenteWeb.Models
@using System.Security.Claims
@model BarrioInteligenteWeb.Models.ReporteDetalleViewModel
@{
    Layout = null;
    ViewData["Title"] = Model.Reporte.Titulo;
    var estado = Model.Reporte.Estado ?? "Pendiente";
    var badgeClass = estado == "Resuelto" ? "resuelto" : (estado == "En Proceso" ? "en-proceso" : "pendiente");
    var tiempoTexto = TiempoHelper.TiempoRelativo(Model.Reporte.Fecha);
    var emoji = Model.Reporte.Categoria switch {
        "Bache"  => "🚧",
        "Basura" => "🗑️",
        "Luz"    => "💡",
        _        => "📍"
    };
    var bgColor = Model.Reporte.Categoria switch {
        "Bache"  => "#f5a623,#d4863a",
        "Basura" => "#7f8c8d,#5a6a6b",
        "Luz"    => "#f9ca24,#d4a017",
        _        => "#636e72,#2d3436"
    };
    var tieneImagen = !string.IsNullOrEmpty(Model.Reporte.ImagenUrl);
    
    int currentUserId = 0;
    if (User.Identity?.IsAuthenticated == true)
    {
        int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out currentUserId);
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@Model.Reporte.Titulo — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <style>
        .comment-form {
            padding: 14px 18px;
            border-top: 1px solid #ebebeb;
            display: flex;
            gap: 10px;
            align-items: flex-end;
            background: #fff;
        }
        .comment-form textarea {
            flex: 1;
            background: #f5f5f5;
            border: 2px solid transparent;
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            resize: none;
            outline: none;
            min-height: 44px;
            max-height: 100px;
            color: #111;
            transition: border-color 0.15s;
        }
        .comment-form textarea:focus {
            border-color: #111;
            background: #fff;
        }
        .comment-form button {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: #111;
            border: none;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            cursor: pointer;
        }

        /* ── Nombres clickeables ── */
        .user-clickable {
            cursor: pointer;
            transition: color 0.15s;
        }
        .user-clickable:hover { color: #3b82f6 !important; }

        /* ── Modal Overlay ── */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 9998;
            align-items: flex-end;
            justify-content: center;
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
        }
        .modal-overlay.active {
            display: flex;
            animation: fadeIn 0.2s ease;
        }

        /* ── Modal Sheet ── */
        .modal-sheet {
            background: #fff;
            width: 100%;
            max-width: 430px;
            border-radius: 20px 20px 0 0;
            padding: 0;
            max-height: 85vh;
            overflow-y: auto;
            animation: slideUp 0.3s cubic-bezier(0.16,1,0.3,1);
        }
        .modal-handle {
            width: 36px;
            height: 4px;
            background: #ddd;
            border-radius: 4px;
            margin: 10px auto 0;
        }

        /* ── Perfil ── */
        .modal-profile {
            text-align: center;
            padding: 20px 24px 16px;
        }
        .modal-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: #f0f0f0;
            margin: 0 auto 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            font-weight: 700;
            color: #555;
            overflow: hidden;
        }
        .modal-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .modal-user-name {
            font-size: 18px;
            font-weight: 800;
            color: #111;
            margin: 0 0 6px;
        }
        .modal-badge-rep {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 12px;
            font-weight: 700;
            padding: 4px 14px;
            border-radius: 20px;
            margin-bottom: 8px;
        }
        .rep-excelente { background: #ecfdf5; color: #059669; border: 1.5px solid #6ee7b7; }
        .rep-buena     { background: #eff6ff; color: #2563eb; border: 1.5px solid #93c5fd; }
        .rep-regular   { background: #fffbeb; color: #d97706; border: 1.5px solid #fcd34d; }
        .rep-mala      { background: #fff1f2; color: #e11d48; border: 1.5px solid #fda4af; }
        .rep-critica   { background: #fef2f2; color: #dc2626; border: 1.5px solid #fca5a5; }
        .modal-member-since {
            font-size: 11px;
            color: #aaa;
        }

        /* ── Botón Reportar ── */
        .btn-reportar-usuario {
            width: calc(100% - 48px);
            margin: 0 24px 16px;
            padding: 14px;
            border-radius: 14px;
            border: 2px solid #fca5a5;
            background: #fff;
            color: #dc2626;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.2s;
        }
        .btn-reportar-usuario:hover {
            background: #fef2f2;
        }

        /* ── Formulario Denuncia ── */
        .denuncia-form {
            display: none;
            padding: 0 24px 24px;
        }
        .denuncia-form.active { display: block; }
        .denuncia-form h4 {
            font-size: 15px;
            font-weight: 700;
            margin: 0 0 14px;
            color: #111;
        }
        .denuncia-select {
            width: 100%;
            padding: 12px 14px;
            border-radius: 12px;
            border: 2px solid #e5e7eb;
            font-size: 13px;
            font-weight: 600;
            color: #111;
            background: #f9fafb;
            outline: none;
            appearance: none;
            margin-bottom: 12px;
            cursor: pointer;
        }
        .denuncia-select:focus { border-color: #dc2626; }
        .denuncia-textarea {
            width: 100%;
            padding: 12px 14px;
            border-radius: 12px;
            border: 2px solid #e5e7eb;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            color: #111;
            background: #f9fafb;
            resize: none;
            outline: none;
            min-height: 70px;
            margin-bottom: 14px;
        }
        .denuncia-textarea:focus { border-color: #dc2626; }
        .btn-enviar-denuncia {
            width: 100%;
            padding: 14px;
            border-radius: 14px;
            border: none;
            background: #dc2626;
            color: #fff;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: background 0.2s;
        }
        .btn-enviar-denuncia:hover { background: #b91c1c; }
        .btn-enviar-denuncia:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        /* ── Toast ── */
        .toast-denuncia {
            position: fixed;
            bottom: 90px;
            left: 50%;
            transform: translateX(-50%);
            padding: 12px 22px;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 600;
            z-index: 99999;
            display: none;
            white-space: nowrap;
            box-shadow: 0 4px 16px rgba(0,0,0,0.25);
        }
        .toast-denuncia.success { background: #065f46; color: #fff; }
        .toast-denuncia.error   { background: #dc2626; color: #fff; }
        .toast-denuncia.visible {
            display: block;
            animation: fadeIn 0.2s ease;
        }

        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @@keyframes slideUp {
            from { transform: translateY(100%); }
            to   { transform: translateY(0); }
        }
    </style>
</head>
<body>
<div class="app-screen">

    <!-- Portada -->
    <div class="detail-cover">
        <a href="@Url.Action("Index", "Reportes")" class="detail-cover-back" aria-label="Volver">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
        </a>

        @if (tieneImagen)
        {
            <img src="@Model.Reporte.ImagenUrl" alt="@Model.Reporte.Titulo"
                 onerror="this.style.display='none';document.getElementById('imgPlaceholder').style.display='flex';" />
            <div id="imgPlaceholder"
                 style="display:none;width:100%;height:100%;background:linear-gradient(135deg,#888 0%,#555 100%);align-items:center;justify-content:center;font-size:70px;">
                @emoji
            </div>
        }
        else
        {
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#b8c1c8 0%,#787e85 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;">
                <span style="font-size:72px;filter:drop-shadow(0 3px 6px rgba(0,0,0,0.3));">@emoji</span>
                <span style="font-size:13px;font-weight:600;color:rgba(255,255,255,0.85);text-transform:uppercase;letter-spacing:1px;">@Model.Reporte.Categoria</span>
            </div>
        }

        <div class="detail-cover-overlay">
            <h1 class="detail-title">@Model.Reporte.Titulo</h1>
            <p class="detail-time">@tiempoTexto</p>
            <span class="badge-estado @badgeClass">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" width="12" height="12">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                @estado
            </span>
            @if (ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin)
            {
                <button class="btn btn-sm btn-danger ms-2" onclick="deleteContent(@Model.Reporte.Id, 'Reporte')" title="Eliminar Reporte completo" style="border-radius:12px;">
                    <i class="bi bi-trash-fill"></i> Eliminar
                </button>
            }
        </div>
    </div>

    <!-- Contenido -->
    <div class="app-body" style="padding-bottom: 200px;">
        <div class="detail-body">
            <p class="detail-descripcion">@Model.Reporte.Descripcion</p>

            <!-- Comentarios -->
            @if (Model.Comentarios.Any())
            {
                @foreach (var comentario in Model.Comentarios)
                {
                    var comRep = comentario.Usuario?.Reputacion ?? NivelReputacion.Regular;
                    var comRingClass = comRep switch {
                        NivelReputacion.Excelente => "avatar-excellent",
                        NivelReputacion.Buena     => "avatar-buena",
                        NivelReputacion.Regular   => "avatar-regular",
                        NivelReputacion.Mala      => "avatar-mala",
                        NivelReputacion.Critica   => "avatar-critica",
                        _ => ""
                    };
                    bool comEsExcelente = comRep == NivelReputacion.Excelente;
                    bool comTieneBadge  = comRep == NivelReputacion.Excelente || comRep == NivelReputacion.Buena;
                    var comNombre = comentario.Usuario?.NombreCompleto ?? "Usuario";
                    var comInicial = comNombre.Length > 0 ? comNombre[0].ToString().ToUpper() : "?";
                    var totalLikes = comentario.Likes?.Count ?? 0;
                    var estaLikeado = comentario.Likes?.Any(l => l.UsuarioId == currentUserId) ?? false;
                    <div class="comment-item">
                        <div class="avatar-wrapper @comRingClass user-clickable" data-user-id="@comentario.UsuarioId" title="Ver perfil de @comNombre">
                            <div class="comment-avatar">
                                @if (!string.IsNullOrEmpty(comentario.Usuario?.FotoPerfil))
                                {
                                    <img src="@comentario.Usuario.FotoPerfil" alt="@comNombre"
                                         style="width:100%;height:100%;border-radius:50%;object-fit:cover;" />
                                }
                                else
                                {
                                    <span style="font-size:15px;font-weight:700;color:#555;">@comInicial</span>
                                }
                            </div>
                            @if (comEsExcelente)
                            {
                                <div class="avatar-badge" title="Ciudadano Excelente">⭐</div>
                            }
                            else if (comTieneBadge)
                            {
                                <div class="avatar-badge" style="background:linear-gradient(135deg,#3b82f6,#2563eb);" title="Buena Reputación">🛡</div>
                            }
                        </div>
                        <div class="comment-content">
                            <p class="comment-user user-clickable" data-user-id="@comentario.UsuarioId">
                                @comNombre
                                @if (ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin)
                                {
                                    <button class="btn btn-sm text-danger p-0 ms-2" onclick="deleteContent(@comentario.Id, 'Comentario')" title="Eliminar Comentario" style="border:none;background:none;">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                }
                            </p>
                            <p class="comment-text">@comentario.Texto</p>
                        </div>
                        
                        <div class="btn-upvote btn-like-comentario" data-comentario-id="@comentario.Id" style="cursor:pointer;color:@(estaLikeado ? "#e74c3c" : "#ccc");display:flex;align-items:center;gap:4px;user-select:none;">
                            @if(estaLikeado)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" class="heart-icon">
                                    <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" class="heart-icon">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
                                </svg>
                            }
                            <span class="likes-count" style="font-size:12px;font-weight:600;">@totalLikes</span>
                        </div>
                    </div>
                }
            }
            else
            {
                <p style="font-size:13px;color:#aaa;text-align:center;padding:20px 0;">Sé el primero en comentar.</p>
            }
        </div>
    </div>

    <!-- Controles -->
    <div style="position:fixed;bottom:64px;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:#fff;z-index:150;border-top:1px solid #ebebeb;">

        <!-- Form Comentario -->
        <form asp-controller="Reportes" asp-action="AgregarComentario" method="post" class="comment-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="reporteId" value="@Model.Reporte.Id" />
            <textarea name="texto" placeholder="Agrega un comentario..." rows="1"></textarea>
            <button type="submit" aria-label="Enviar comentario">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/>
                </svg>
            </button>
        </form>

        <!-- Boton Reporte -->
        <div style="padding:10px 18px;">
            <button type="button" 
                    id="btn-confirmar-detalle"
                    class="btn btn-outline-secondary w-100 d-flex justify-content-center align-items-center gap-2" 
                    data-reporte-id="@Model.Reporte.Id"
                    style="height: 48px; border-radius: 12px; font-weight: 600; font-size: 15px; background-color: #ffffff;">
                <i class="bi @(Model.YaVoto ? "bi-heart-fill text-danger" : "bi-heart")"></i>
                <span class="texto-contador @(Model.YaVoto ? "text-danger fw-bold" : "")" style="color:#555">
                    <span class="texto-estado">@(Model.YaVoto ? "Confirmado" : "Confirmar Reporte")</span> 
                    (<span class="conteo">@Model.Reporte.Upvotes</span>)
                </span>
            </button>
        </div>
    </div>

    <!-- Menu -->
    <nav class="bottom-nav">
        <a href="@Url.Action("Index", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/>
            </svg>
            <span>Mapa</span>
        </a>
        <a href="@Url.Action("MisReportes", "Reportes")" class="active">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
            </svg>
            <span>Mis Reportes</span>
        </a>
        <a href="@Url.Action("Perfil", "Account")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
            </svg>
            <span>Perfil</span>
        </a>
    
          <a href="@Url.Action("Dashboard", "Reportes")">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
              </svg>
              <span>Panel</span>
          </a>
      </nav>

</div>

<!-- ══════════════════════════════════════════ -->
<!-- MODAL: Perfil de Usuario + Denuncia       -->
<!-- ══════════════════════════════════════════ -->
<div class="modal-overlay" id="modalPerfilOverlay">
    <div class="modal-sheet">
        <div class="modal-handle"></div>

        <!-- Perfil -->
        <div class="modal-profile" id="modalPerfilContent">
            <div class="modal-avatar" id="modalAvatar">
                <span id="modalAvatarInicial">?</span>
            </div>
            <p class="modal-user-name" id="modalUserName">Cargando...</p>
            <span class="modal-badge-rep" id="modalBadgeRep"></span>
            <p class="modal-member-since" id="modalMemberSince"></p>
        </div>

        <!-- Botón Reportar -->
        <button class="btn-reportar-usuario" id="btnMostrarDenuncia">
            🚩 Reportar Usuario
        </button>

        @if (ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin)
        {
            <div style="padding: 0 24px 20px;">
                <hr style="border-color:#eee;"/>
                <h6 style="font-weight:700; color:#dc2626; font-size:13px; text-transform:uppercase; margin-bottom:12px;">👑 Herramientas de Admin</h6>
                <div style="display:flex; flex-direction:column; gap:8px;">
                    <button class="btn btn-dark w-100 fw-bold" onclick="resetearReputacionModal()">
                        <i class="bi bi-arrow-counterclockwise"></i> Resetear Reputación (a 100 pts)
                    </button>
                    <a href="/Admin/Panel" class="btn btn-outline-dark w-100 fw-bold">
                        <i class="bi bi-award"></i> Asignar Insignia
                    </a>
                    <button class="btn btn-outline-danger w-100 fw-bold" onclick="alert('Historial de denuncias en construcción. Redirigiendo al panel.'); window.location.href='/Admin/Panel';">
                        <i class="bi bi-card-list"></i> Ver Denuncias Previas
                    </button>
                </div>
            </div>
        }

        <!-- Formulario de Denuncia (oculto por defecto) -->
        <div class="denuncia-form" id="denunciaForm">
            <h4>¿Por qué reportas a este usuario?</h4>
            <select class="denuncia-select" id="denunciaMotivo">
                <option value="" disabled selected>Selecciona un motivo...</option>
                <option value="Spam">📢 Spam o publicidad</option>
                <option value="Comportamiento indebido">😤 Comportamiento indebido</option>
                <option value="Contenido ofensivo">🤬 Contenido ofensivo</option>
                <option value="Información falsa">❌ Información falsa</option>
                <option value="Acoso">⚠️ Acoso o intimidación</option>
                <option value="Otro">📝 Otro</option>
            </select>
            <textarea class="denuncia-textarea" id="denunciaDescripcion" placeholder="Describe brevemente lo ocurrido (opcional)..."></textarea>
            <button class="btn-enviar-denuncia" id="btnEnviarDenuncia" disabled>Enviar Denuncia</button>
        </div>
    </div>
</div>

<!-- Toast de feedback -->
<div class="toast-denuncia" id="toastDenuncia"></div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        // ═════════════════════════════════════════
        // SISTEMA DE MODAL DE PERFIL + DENUNCIA
        // ═════════════════════════════════════════
        const modalOverlay = document.getElementById('modalPerfilOverlay');
        const modalAvatar = document.getElementById('modalAvatar');
        const modalAvatarInicial = document.getElementById('modalAvatarInicial');
        const modalUserName = document.getElementById('modalUserName');
        const modalBadgeRep = document.getElementById('modalBadgeRep');
        const modalMemberSince = document.getElementById('modalMemberSince');
        const btnMostrarDenuncia = document.getElementById('btnMostrarDenuncia');
        const denunciaForm = document.getElementById('denunciaForm');
        const denunciaMotivo = document.getElementById('denunciaMotivo');
        const denunciaDescripcion = document.getElementById('denunciaDescripcion');
        const btnEnviarDenuncia = document.getElementById('btnEnviarDenuncia');
        const toastDenuncia = document.getElementById('toastDenuncia');

        let usuarioReportadoId = null;

        // Abrir modal al hacer clic en nombre o avatar
        document.querySelectorAll('.user-clickable').forEach(el => {
            el.addEventListener('click', async function (e) {
                e.stopPropagation();
                const userId = this.dataset.userId;
                if (!userId) return;

                usuarioReportadoId = parseInt(userId);
                denunciaForm.classList.remove('active');
                denunciaMotivo.value = '';
                denunciaDescripcion.value = '';
                btnEnviarDenuncia.disabled = true;

                // Mostrar modal con loading
                modalUserName.textContent = 'Cargando...';
                modalBadgeRep.textContent = '';
                modalMemberSince.textContent = '';
                modalAvatarInicial.textContent = '...';
                modalAvatar.innerHTML = '<span id="modalAvatarInicial">...</span>';
                modalOverlay.classList.add('active');

                try {
                    const resp = await fetch(`@Url.Action("ObtenerPerfilPublico", "Denuncias")?id=${userId}`);
                    const json = await resp.json();

                    if (json.success) {
                        const u = json.data;
                        modalUserName.textContent = u.nombre;
                        modalMemberSince.textContent = `Miembro desde ${u.miembro}`;

                        // Avatar
                        if (u.foto) {
                            modalAvatar.innerHTML = `<img src="${u.foto}" alt="${u.nombre}" />`;
                        } else {
                            const inicial = u.nombre.charAt(0).toUpperCase();
                            modalAvatar.innerHTML = `<span style="font-size:28px;font-weight:700;color:#555;">${inicial}</span>`;
                        }

                        // Badge de reputación
                        const nivelMap = {
                            'Excelente': { emoji: '⭐', cls: 'rep-excelente', label: 'Ciudadano Excelente' },
                            'Buena':     { emoji: '🛡️', cls: 'rep-buena',     label: 'Buena Reputación' },
                            'Regular':   { emoji: '⚖️', cls: 'rep-regular',   label: 'Reputación Regular' },
                            'Mala':      { emoji: '⚠️', cls: 'rep-mala',      label: 'Reputación Baja' },
                            'Critica':   { emoji: '🔴', cls: 'rep-critica',   label: 'Reputación Crítica' }
                        };
                        const info = nivelMap[u.nivel] || nivelMap['Regular'];
                        modalBadgeRep.className = `modal-badge-rep ${info.cls}`;
                        modalBadgeRep.innerHTML = `${info.emoji} ${info.label}`;
                    } else {
                        modalUserName.textContent = 'Usuario no encontrado';
                    }
                } catch (err) {
                    console.error('[Modal] Error:', err);
                    modalUserName.textContent = 'Error al cargar perfil';
                }
            });
        });

        // Cerrar modal al tocar overlay
        modalOverlay.addEventListener('click', function (e) {
            if (e.target === modalOverlay) {
                modalOverlay.classList.remove('active');
            }
        });

        // Mostrar formulario de denuncia
        btnMostrarDenuncia.addEventListener('click', function () {
            denunciaForm.classList.toggle('active');
        });

        // Habilitar botón cuando se selecciona motivo
        denunciaMotivo.addEventListener('change', function () {
            btnEnviarDenuncia.disabled = !this.value;
        });

        // Enviar denuncia
        btnEnviarDenuncia.addEventListener('click', async function () {
            if (!usuarioReportadoId || !denunciaMotivo.value) return;

            this.disabled = true;
            this.textContent = 'Enviando...';

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            try {
                const formData = new FormData();
                formData.append('usuarioReportadoId', usuarioReportadoId);
                formData.append('motivo', denunciaMotivo.value);
                formData.append('descripcion', denunciaDescripcion.value.trim());

                const resp = await fetch('@Url.Action("ReportarPerfil", "Denuncias")', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });

                const data = await resp.json();

                // Cerrar modal
                modalOverlay.classList.remove('active');

                // Mostrar toast
                showToast(
                    data.success
                        ? '✅ Denuncia enviada. El equipo de moderación (Chris) ha sido notificado.'
                        : `⚠️ ${data.message}`,
                    data.success ? 'success' : 'error'
                );
            } catch (err) {
                console.error('[Denuncia] Error:', err);
                showToast('❌ Error de conexión al enviar la denuncia.', 'error');
            } finally {
                this.disabled = false;
                this.textContent = 'Enviar Denuncia';
            }
        });

        @if (ViewBag.EsAdmin != null && (bool)ViewBag.EsAdmin)
        {
            <text>
            window.resetearReputacionModal = async function() {
                if(!usuarioReportadoId) return;
                if(!confirm('¿Estás seguro de que quieres resetear la reputación de este usuario a 100 puntos (Excelente)?')) return;
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                const fd = new FormData();
                fd.append('usuarioId', usuarioReportadoId);
                fd.append('puntosForm', 100);
                try {
                    const res = await fetch('/Admin/AjustarReputacion', {
                        method: 'POST', headers: { 'RequestVerificationToken': token }, body: fd
                    });
                    const result = await res.json();
                    if(result.success) {
                        showToast('Reputación reseteada a 100.', 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showToast('Error: ' + result.message, 'error');
                    }
                }catch(e) { console.error(e); }
            };
            </text>
        }

        function showToast(msg, type) {
            toastDenuncia.textContent = msg;
            toastDenuncia.className = `toast-denuncia ${type} visible`;
            setTimeout(() => { toastDenuncia.classList.remove('visible'); }, 4000);
        }

        // ═════════════════════════════════════════
        // LIKES DE COMENTARIOS (existente)
        // ═════════════════════════════════════════
        const likeButtons = document.querySelectorAll('.btn-like-comentario');
        
        likeButtons.forEach(btn => {
            btn.addEventListener('click', async function () {
                const comentarioId = this.dataset.comentarioId;
                const url = '@Url.Action("ToggleLikeComentario", "Reportes")';
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                
                // Animacion
                this.style.transform = 'scale(1.2)';
                setTimeout(() => this.style.transform = 'scale(1)', 150);
                this.style.transition = 'transform 0.15s ease-out';

                try {
                    const formData = new FormData();
                    formData.append('id', comentarioId);
                    
                    const response = await fetch(url, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });
                    
                    if (response.ok) {
                        const data = await response.json();
                        if (data.success) {
                            const countSpan = this.querySelector('.likes-count');
                            countSpan.textContent = data.totalLikes;
                            
                            if (data.estaLikeado) {
                                this.style.color = '#e74c3c';
                                this.innerHTML = `
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" class="heart-icon">
                                        <path d="m11.645 20.91-.007-.003-.022-.012a15.247 15.247 0 0 1-.383-.218 25.18 25.18 0 0 1-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0 1 12 5.052 5.5 5.5 0 0 1 16.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 0 1-4.244 3.17 15.247 15.247 0 0 1-.383.219l-.022.012-.007.004-.003.001a.752.752 0 0 1-.704 0l-.003-.001Z" />
                                    </svg>
                                    <span class="likes-count" style="font-size:12px;font-weight:600;">${data.totalLikes}</span>
                                `;
                            } else {
                                this.style.color = '#ccc';
                                this.innerHTML = `
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" class="heart-icon">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"/>
                                    </svg>
                                    <span class="likes-count" style="font-size:12px;font-weight:600;">${data.totalLikes}</span>
                                `;
                            }
                        }
                    }
                } catch (error) {
                    console.error('Error al hacer toggle like:', error);
                }
            });
        });

        // Script para confirmar reporte en Detalles (AJAX similar a Comunidad)
        const btnConfirmarDetalle = document.getElementById('btn-confirmar-detalle');
        if (btnConfirmarDetalle) {
            btnConfirmarDetalle.addEventListener('click', async function(e) {
                e.preventDefault();
                const reporteId = this.getAttribute('data-reporte-id');
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                // Animacion sutil
                this.style.transform = 'scale(0.98)';
                setTimeout(() => this.style.transform = 'scale(1)', 150);
                this.style.transition = 'transform 0.15s ease-out';

                try {
                    const formData = new FormData();
                    formData.append('id', reporteId);

                    const response = await fetch('@Url.Action("ConfirmarReporte", "Reportes")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token,
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: formData
                    });

                    if (response.ok) {
                        const data = await response.json();
                        if (data.success) {
                            const icono = this.querySelector('i.bi');
                            const textoContador = this.querySelector('.texto-contador');
                            const spanConteo = this.querySelector('.conteo');
                            const textoEstado = this.querySelector('.texto-estado');

                            spanConteo.textContent = data.nuevoConteo;

                            if (data.estaConfirmado) {
                                icono.classList.remove('bi-heart');
                                icono.classList.add('bi-heart-fill', 'text-danger');
                                textoContador.classList.add('text-danger', 'fw-bold');
                                textoEstado.textContent = 'Confirmado';
                            } else {
                                icono.classList.remove('bi-heart-fill', 'text-danger');
                                icono.classList.add('bi-heart');
                                textoContador.classList.remove('text-danger', 'fw-bold');
                                textoEstado.textContent = 'Confirmar Reporte';
                            }
                        } else {
                            alert(data.message || 'Error al procesar la confirmación.');
                        }
                    }
                } catch (error) {
                    console.error('Error al confirmar reporte:', error);
                }
            });
        }
    });

    async function deleteContent(id, tipo) {
        if (!confirm('¿Seguro que deseas eliminar este ' + tipo.toLowerCase() + ' de la plataforma?')) return;
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const formData = new FormData();
        formData.append('id', id);
        formData.append('tipo', tipo);

        try {
            const res = await fetch('/Admin/EliminarContenido', {
                method: 'POST', headers: { 'RequestVerificationToken': token }, body: formData
            });
            const data = await res.json();
            if (data.success) {
                alert(data.message);
                if(tipo === 'Reporte') {
                    window.location.href = '/Reportes/Index';
                } else {
                    location.reload();
                }
            } else {
                alert(data.message);
            }
        } catch(e) { console.error(e); }
    }
</script>
</body>
</html>
