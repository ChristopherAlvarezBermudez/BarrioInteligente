@using BarrioInteligenteWeb.Models
@{
    Layout = null;
    ViewData["Title"] = "Dashboard de Inteligencia Urbana";
    var topCiudadanos = ViewBag.TopCiudadanos as List<Usuario> ?? new List<Usuario>();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
</head>
<body>
    <div class="app-screen">
        <header class="app-header">
            <h1 class="app-title">📊 Panel de Control</h1>
        </header>

        <div class="app-body" style="padding: 16px 16px 80px;">
            <div class="container-fluid p-0">
                <div class="row mb-4">
                    <div class="col-12">
                        <p class="text-muted">Análisis de datos de reportes ciudadanos</p>
                    </div>
                </div>

                <div class="row g-4">
                    <!-- Gráfico Categorías -->
                    <div class="col-md-12">
                        <div class="card shadow-sm h-100 border-0 rounded-4">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-secondary mb-4">Reportes por Categoría</h5>
                                <div class="position-relative" style="height: 300px;">
                                    <canvas id="chartCategorias"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Gráfico Estados -->
                    <div class="col-md-12">
                        <div class="card shadow-sm h-100 border-0 rounded-4">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-secondary mb-4">Estado de los Reportes</h5>
                                <div class="position-relative" style="height: 300px;">
                                    <canvas id="chartEstados"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Top Ciudadanos -->
                    <div class="col-md-12">
                        <div class="card shadow-sm h-100 border-0 rounded-4">
                            <div class="card-header bg-white border-0 pt-4 pb-2">
                                <h5 class="card-title fw-bold text-secondary m-0">🏆 Top Ciudadanos</h5>
                            </div>
                            <div class="card-body">
                                <ul class="list-group list-group-flush">
                                    @foreach (var usuario in topCiudadanos)
                                    {
                                        var badgeColor = usuario.Reputacion switch {
                                            NivelReputacion.Excelente => "bg-success",
                                            NivelReputacion.Buena => "bg-primary",
                                            NivelReputacion.Regular => "bg-warning",
                                            NivelReputacion.Mala => "bg-danger",
                                            NivelReputacion.Critica => "bg-dark",
                                            _ => "bg-secondary"
                                        };

                                        <li class="list-group-item px-0 border-0 mb-3 pt-2">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3 position-relative">
                                                    @if (!string.IsNullOrEmpty(usuario.FotoPerfil))
                                                    {
                                                        <img src="@usuario.FotoPerfil" alt="@usuario.NombreCompleto" class="rounded-circle border border-2 border-white shadow-sm" style="width: 50px; height: 50px; object-fit: cover;">
                                                    }
                                                    else
                                                    {
                                                        <div class="rounded-circle shadow-sm d-flex align-items-center justify-content-center text-white fw-bold @badgeColor" style="width: 50px; height: 50px; font-size: 1.2rem;">
                                                            @usuario.NombreCompleto.Substring(0, 1).ToUpper()
                                                        </div>
                                                    }
                                                    <span class="position-absolute bottom-0 start-100 translate-middle p-1 bg-white border border-light rounded-circle" title="@usuario.Reputacion">
                                                        <span class="badge @badgeColor rounded-circle p-1" style="width: 15px; height: 15px; display: inline-block;"></span>
                                                    </span>
                                                </div>
                                                <div>
                                                    <h6 class="mb-1 fw-bold text-dark text-truncate" style="max-width: 120px;">@usuario.NombreCompleto</h6>
                                                    <small class="text-muted d-block fw-medium">@usuario.PuntosReputacion pts</small>
                                                </div>
                                            </div>
                                        </li>
                                    }
                                    @if (!topCiudadanos.Any())
                                    {
                                        <li class="list-group-item px-0 border-0 text-muted">No hay ciudadanos destacados aún.</li>
                                    }
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <nav class="bottom-nav">
          <a href="@Url.Action("Index", "Reportes")">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              <span>Mapa</span>
          </a>
          <a href="@Url.Action("MisReportes", "Reportes")">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3Z" />
              </svg>
              <span>Mis Reportes</span>
          </a>
          <a href="@Url.Action("Comunidad", "Reportes")">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
              </svg>
              <span>Comunidad</span>
          </a>
          <a href="@Url.Action("Dashboard", "Reportes")" class="active">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
              </svg>
              <span>Panel</span>
          </a>
        </nav>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Datos desde ViewBag
            const dataCategorias = @Html.Raw(ViewBag.DataCategorias ?? "[]");
            const dataEstados = @Html.Raw(ViewBag.DataEstados ?? "[]");

            // Configurar Gráfico Categorías (Doughnut)
            const ctxCat = document.getElementById('chartCategorias').getContext('2d');
            new Chart(ctxCat, {
                type: 'doughnut',
                data: {
                    labels: dataCategorias.map(d => d.Categoria || d.categoria),
                    datasets: [{
                        data: dataCategorias.map(d => d.Count || d.count),
                        backgroundColor: ['#10B981', '#3B82F6', '#F59E0B', '#EF4444', '#8B5CF6'],
                        borderWidth: 0,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            labels: {
                                font: { family: "'Inter', sans-serif", size: 13 },
                                usePointStyle: true,
                                padding: 20
                            }
                        }
                    },
                    cutout: '70%',
                    layout: { padding: 10 }
                }
            });

            // Configurar Gráfico Estados (Bar)
            const ctxEst = document.getElementById('chartEstados').getContext('2d');
            new Chart(ctxEst, {
                type: 'bar',
                data: {
                    labels: dataEstados.map(d => d.Estado || d.estado),
                    datasets: [{
                        label: 'Reportes Activos',
                        data: dataEstados.map(d => d.Count || d.count),
                        backgroundColor: ['#6366F1', '#EC4899', '#14B8A6'],
                        borderRadius: 6,
                        barThickness: 'flex',
                        maxBarThickness: 45
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0, font: { family: "'Inter', sans-serif" } },
                            grid: { borderDash: [5, 5], color: '#e5e7eb' },
                            border: { display: false }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { font: { family: "'Inter', sans-serif", weight: '500' } },
                            border: { display: false }
                        }
                    },
                    layout: { padding: { top: 10, bottom: 10 } }
                }
            });
        });
    </script>
</body>
</html>
