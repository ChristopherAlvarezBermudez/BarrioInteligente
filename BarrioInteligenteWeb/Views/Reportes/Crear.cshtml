@model BarrioInteligenteWeb.Models.Reporte
@{
    Layout = null;
    ViewData["Title"] = "Nuevo Reporte";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Nuevo Reporte — Barrio Inteligente</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/barrio.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map-picker {
            width: 100%;
            height: 220px;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid #e0e0e0;
            z-index: 0;
        }
        .map-picker-label {
            font-size: 12px;
            color: #888;
            text-align: center;
            margin-top: 6px;
        }
        .location-confirmed {
            background: #f0fff4 !important;
            border-color: #34d399 !important;
        }
    </style>
</head>
<body>
<div class="app-screen">

    <header class="app-header">
        <a href="@Url.Action("Index", "Reportes")" class="btn-back" aria-label="Volver al mapa">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
            </svg>
        </a>
        <span class="app-title">Nuevo Reporte</span>
        @{
            string? fotoPerfil = ViewBag.FotoPerfil as string;
        }
        <a href="@Url.Action("Perfil", "Account")" class="btn-user-icon" aria-label="Perfil"
           style="@(!string.IsNullOrEmpty(fotoPerfil) ? "padding:0;overflow:hidden;border-radius:50%;" : "")">
            @if (!string.IsNullOrEmpty(fotoPerfil))
            {
                <img src="@fotoPerfil" alt="Mi perfil" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;" />
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
                </svg>
            }
        </a>
    </header>

    <div class="app-body">
        <form asp-action="Crear" asp-controller="Reportes" method="post" enctype="multipart/form-data" class="form-body">
            @Html.AntiForgeryToken()

            @if (ViewBag.ErrorGuardado != null)
            {
                <div style="background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;padding:12px 14px;font-size:13px;color:#c0392b;">
                    @ViewBag.ErrorGuardado
                </div>
            }

            <!-- Imagen -->
            <label for="imgInput" class="img-upload-box" id="imgUploadLabel">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/>
                </svg>
                <span>Adjunte imagen para el reporte</span>
                <input type="file" id="imgInput" name="imagen" accept="image/*" class="hidden-input" />
            </label>

            <!-- Ubicacion GPS -->
            <div class="location-field" id="locationField">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
                </svg>
                <span id="ubicacionTexto">Obteniendo ubicación GPS...</span>
                <input type="hidden" asp-for="Ubicacion" id="Ubicacion" />
                <input type="hidden" asp-for="Latitud" id="Latitud" value="0" />
                <input type="hidden" asp-for="Longitud" id="Longitud" value="0" />
                <input type="hidden" asp-for="DireccionFisica" id="DireccionFisica" />
            </div>

            <!-- Mapa Picker -->
            <div>
                <div id="map-picker"></div>
                <p class="map-picker-label" id="mapPickerHint">📍 Toca el mapa para ajustar la ubicación exacta</p>
            </div>

            <!-- Categorias -->
            <div class="categories-grid" id="categorias">
                <button type="button" class="category-btn" data-categoria="Bache" onclick="seleccionarCategoria(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/>
                    </svg>
                    <span>Bache</span>
                </button>
                <button type="button" class="category-btn" data-categoria="Basura" onclick="seleccionarCategoria(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/>
                    </svg>
                    <span>Basura</span>
                </button>
                <button type="button" class="category-btn" data-categoria="Luz" onclick="seleccionarCategoria(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                    </svg>
                    <span>Luz</span>
                </button>
                <button type="button" class="category-btn" data-categoria="Otro" onclick="seleccionarCategoria(this)">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.6" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM12.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0ZM18.75 12a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z"/>
                    </svg>
                    <span>Otro</span>
                </button>
            </div>
            <input type="hidden" asp-for="Categoria" id="categoriaInput" />

            <!-- Descripcion -->
            <div class="desc-box">
                <p>Descripción del reporte</p>
                <textarea asp-for="Descripcion" rows="4" placeholder="Describe el problema con detalle. ¿Qué tan peligroso es? ¿Cuánto tiempo lleva así?" required></textarea>
            </div>

            <input type="hidden" asp-for="Titulo" id="tituloInput" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="background:#fff0f0;border:1px solid #ffcccc;border-radius:10px;padding:12px 14px;font-size:13px;color:#c0392b;">
                    Por favor completa todos los campos requeridos: categoría, descripción y ubicación.
                </div>
            }

            <button type="submit" class="btn-primary-black" id="btnSubir">
                SUBIR REPORTE
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.2" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18"/>
                </svg>
            </button>
        </form>
    </div>

    <nav class="bottom-nav">
        <a href="@Url.Action("Index", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c-.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/>
            </svg>
            <span>Mapa</span>
        </a>
        <a href="@Url.Action("MisReportes", "Reportes")" class="active">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>
            </svg>
            <span>Mis Reportes</span>
        </a>
        <a href="@Url.Action("Comunidad", "Reportes")">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/>
            </svg>
            <span>Comunidad</span>
        </a>
    </nav>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    // Mapa Picker
    let pickerMap = L.map('map-picker').setView([18.4861, -69.9312], 14);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap',
        maxZoom: 19
    }).addTo(pickerMap);

    const markerIcon = L.divIcon({
        html: '<div style="font-size:28px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.4))">📍</div>',
        className: '',
        iconSize: [30, 30],
        iconAnchor: [15, 30]
    });

    let marcador = null;

    let timeoutGeocoding = null;

    async function obtenerDireccion(lat, lon) {
        try {
            document.getElementById('ubicacionTexto').textContent = '📍 Buscando dirección...';
            const res = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`);
            if (res.ok) {
                const data = await res.json();
                
                let direccion = "";
                if (data.address) {
                    const calle = data.address.road || data.address.pedestrian || "";
                    const barrio = data.address.suburb || data.address.neighbourhood || data.address.village || data.address.city_district || "";
                    const ciudad = data.address.city || data.address.town || "";
                    
                    const partes = [];
                    if (calle) partes.push(calle);
                    if (barrio) partes.push(barrio);
                    if (ciudad && !barrio.includes(ciudad)) partes.push(ciudad);
                    
                    direccion = partes.join(", ");
                }
                
                if (!direccion) direccion = data.display_name;

                document.getElementById('DireccionFisica').value = direccion;
                document.getElementById('ubicacionTexto').textContent = '📍 ' + direccion;
            } else {
                document.getElementById('ubicacionTexto').textContent = '📍 Lat ' + lat.toFixed(5) + ', Lon ' + lon.toFixed(5);
            }
        } catch (error) {
            console.error("Geocoding error", error);
            document.getElementById('ubicacionTexto').textContent = '📍 Lat ' + lat.toFixed(5) + ', Lon ' + lon.toFixed(5);
        }
    }

    function actualizarCoordenadas(lat, lon) {
        document.getElementById('Latitud').value = lat;
        document.getElementById('Longitud').value = lon;
        document.getElementById('Ubicacion').value = 'Lat: ' + lat.toFixed(5) + ', Lon: ' + lon.toFixed(5);
        document.getElementById('locationField').classList.add('location-confirmed');
        document.getElementById('mapPickerHint').textContent = '✅ Ubicación confirmada. Toca otro punto para cambiar.';
        
        // DebounceNominatim
        clearTimeout(timeoutGeocoding);
        document.getElementById('ubicacionTexto').textContent = '📍 Lat ' + lat.toFixed(5) + ', Lon ' + lon.toFixed(5);
        timeoutGeocoding = setTimeout(() => obtenerDireccion(lat, lon), 700);
    }

    pickerMap.on('click', function (e) {
        const { lat, lng } = e.latlng;
        if (marcador) {
            marcador.setLatLng([lat, lng]);
        } else {
            marcador = L.marker([lat, lng], { icon: markerIcon, draggable: true }).addTo(pickerMap);
            marcador.on('dragend', function () {
                const p = marcador.getLatLng();
                actualizarCoordenadas(p.lat, p.lng);
            });
        }
        actualizarCoordenadas(lat, lng);
    });

    // GPS Automatico
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(function (pos) {
            const lat = pos.coords.latitude;
            const lon = pos.coords.longitude;
            pickerMap.setView([lat, lon], 16);
            marcador = L.marker([lat, lon], { icon: markerIcon, draggable: true }).addTo(pickerMap);
            marcador.on('dragend', function () {
                const p = marcador.getLatLng();
                actualizarCoordenadas(p.lat, p.lng);
            });
            actualizarCoordenadas(lat, lon);
        }, function () {
            document.getElementById('ubicacionTexto').textContent = 'Toca el mapa para seleccionar ubicación.';
        }, { enableHighAccuracy: true, timeout: 10000 });
    }

    // Categorias
    function seleccionarCategoria(btn) {
        document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        document.getElementById('categoriaInput').value = btn.dataset.categoria;
        document.getElementById('tituloInput').value = btn.dataset.categoria + ' en ' +
            (document.getElementById('Ubicacion').value || 'zona reportada');
    }

    // Preview Imagen
    document.getElementById('imgInput').addEventListener('change', function () {
        if (this.files && this.files[0]) {
            const label = document.getElementById('imgUploadLabel');
            label.style.backgroundImage = 'url(' + URL.createObjectURL(this.files[0]) + ')';
            label.style.backgroundSize = 'cover';
            label.style.backgroundPosition = 'center';
            label.querySelector('svg').style.display = 'none';
            label.querySelector('span').style.display = 'none';
        }
    });

    // Validacion Form
    document.querySelector('form').addEventListener('submit', function (e) {
        if (!document.getElementById('categoriaInput').value) {
            e.preventDefault();
            alert('Por favor selecciona una categoría.');
            return;
        }
        document.getElementById('btnSubir').textContent = 'Subiendo...';
        document.getElementById('btnSubir').disabled = true;
    });
</script>
</body>
</html>